<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Campaign Management System{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ static('css/app.css') }}">
    {% block extra_head %}{% endblock %}
</head>
<body>
    <nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top">
        <div class="container">
            <a class="navbar-brand fw-semibold" href="{{ url('home') }}">Campaign Management</a>
            <div class="d-flex gap-2 align-items-center">
                <a class="btn btn-link text-decoration-none" href="{{ url('support_center:landing', user_type='doctor') }}">Doctor Support</a>
                <a class="btn btn-link text-decoration-none" href="{{ url('support_center:landing', user_type='clinic_staff') }}">Clinic Staff</a>
                <a class="btn btn-link text-decoration-none" href="{{ url('support_center:landing', user_type='brand_manager') }}">Brand Manager</a>
                <a class="btn btn-link text-decoration-none" href="{{ url('support_center:landing', user_type='field_rep') }}">Field Rep</a>
                <a class="btn btn-link text-decoration-none" href="{{ url('support_center:landing', user_type='patient') }}">Patient</a>
                {% if request.user.is_authenticated %}
                    <a class="btn btn-outline-secondary" href="{{ url('ticketing:list') }}">Ticketing</a>
                    <a class="btn btn-outline-secondary" href="{{ url('reporting:contracts') }}">API Contracts</a>
                    {% if request.user.is_project_manager or request.user.is_superuser %}
                        <a class="btn btn-primary" href="{{ url('dashboards:home') }}">PM Dashboard</a>
                    {% endif %}
                    <a class="btn btn-link text-decoration-none" href="{{ url('account_logout') }}">Log out</a>
                {% else %}
                    <a class="btn btn-primary" href="{{ url('account_login') }}">Sign in</a>
                {% endif %}
            </div>
        </div>
    </nav>
    <main class="pb-5">
        <div class="container py-4">
            {% if messages %}
                <div class="mb-4">
                    {% for message in messages %}
                        <div class="alert alert-{{ message.tags or 'info' }}">{{ message }}</div>
                    {% endfor %}
                </div>
            {% endif %}
            {% block content %}{% endblock %}
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
