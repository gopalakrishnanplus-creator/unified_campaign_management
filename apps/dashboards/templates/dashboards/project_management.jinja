{% extends "base.jinja" %}
{% block title %}Project Management Dashboard{% endblock %}
{% block extra_head %}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.0/dist/chart.umd.min.js"></script>
{% endblock %}
{% block content %}
<div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-3">
    <div>
        <p class="eyebrow mb-1">Project Management Dashboard</p>
        <h1 class="mb-0">Ticket and support command center</h1>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary" href="{{ url('dashboards:performance') }}">Campaign performance</a>
        <a class="btn btn-outline-secondary" href="{{ url('ticketing:distribution') }}">Ticket trends</a>
    </div>
</div>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
        <div>
            <p class="eyebrow mb-1">Ticket Overview</p>
            <h2 class="h3 mb-0">Decision-ready summary</h2>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button
                class="btn btn-outline-secondary"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#dashboard-visualizations"
                aria-expanded="false"
                aria-controls="dashboard-visualizations"
                id="toggle-visualizations"
            >
                View Visualizations
            </button>
            <a class="btn btn-outline-secondary" href="{{ url('ticketing:list') }}">Open full queue</a>
            <a class="btn btn-primary" href="{{ url('ticketing:create') }}">Create ticket</a>
        </div>
    </div>

    <div class="row g-2 mb-3">
        {% for card in support_data.overview_cards %}
            <div class="col-md-6 col-xl">
                <a class="metric-card metric-card-link h-100 text-decoration-none" href="{{ card.url }}">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <span class="metric-label">{{ card.label }}</span>
                        <span class="status-code-pill {{ card.badge_class }}">{{ card.badge }}</span>
                    </div>
                    <div class="metric-value">{{ card.value }}</div>
                    <div class="small text-secondary mt-2">{{ card.subtitle }}</div>
                </a>
            </div>
        {% endfor %}
    </div>

    <div class="collapse" id="dashboard-visualizations">
        <div class="row g-3">
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 h-100">
                    <div class="card-body">
                        <h3 class="h5 mb-3">Ticket distribution by category</h3>
                        <div class="chart-panel mb-3">
                            <canvas id="pm-category-chart"></canvas>
                        </div>
                        <div class="chart-legend-list">
                            {% for row in support_data.category_breakdown %}
                                <a class="chart-legend-item text-decoration-none text-reset" href="{{ row.url }}">
                                    <span class="chart-legend-swatch" style="background: {{ row.color }};"></span>
                                    <span class="chart-legend-label">{{ row.label }}</span>
                                    <strong>{{ row.count }}</strong>
                                </a>
                            {% else %}
                                <p class="text-secondary mb-0">No category data yet.</p>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 h-100">
                    <div class="card-body">
                        <h3 class="h5 mb-3">Status breakdown</h3>
                        <div class="chart-panel mb-3">
                            <canvas id="pm-status-chart"></canvas>
                        </div>
                        <div class="chart-legend-list">
                            {% for row in support_data.status_breakdown %}
                                <a class="chart-legend-item text-decoration-none text-reset" href="{{ row.url }}">
                                    <span class="status-pill {{ row.badge_class }}">{{ row.label }}</span>
                                    <strong>{{ row.count }}</strong>
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 h-100">
                    <div class="card-body">
                        <h3 class="h5 mb-3">Priority levels</h3>
                        <div class="chart-panel mb-3">
                            <canvas id="pm-priority-chart"></canvas>
                        </div>
                        <div class="chart-legend-list">
                            {% for row in support_data.priority_breakdown %}
                                <a class="chart-legend-item text-decoration-none text-reset" href="{{ row.url }}">
                                    <span class="priority-pill {{ row.badge_class }}">{{ row.label }}</span>
                                    <strong>{{ row.count }}</strong>
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
        <div>
            <p class="eyebrow mb-1">Widget Activity</p>
            <h2 class="h3 mb-0">System-wise support widget counts</h2>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>System</th>
                        <th>Widget Opened</th>
                        <th>Resolved</th>
                        <th>Send Ticket</th>
                        <th>PM Raised Ticket</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in support_data.widget_activity_rows %}
                        <tr>
                            <td class="fw-semibold">{{ row.system }}</td>
                            <td>{{ row.widget_open_count }}</td>
                            <td>{{ row.resolved_count }}</td>
                            <td>{{ row.send_ticket_count }}</td>
                            <td>{{ row.pm_raised_ticket_count }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="5" class="text-secondary">No widget activity recorded yet.</td></tr>
                    {% endfor %}
                </tbody>
                {% if support_data.widget_activity_rows %}
                    <tfoot>
                        <tr>
                            <th>Total</th>
                            <th>{{ support_data.widget_activity_totals.widget_open_count }}</th>
                            <th>{{ support_data.widget_activity_totals.resolved_count }}</th>
                            <th>{{ support_data.widget_activity_totals.send_ticket_count }}</th>
                            <th>{{ support_data.widget_activity_totals.pm_raised_ticket_count }}</th>
                        </tr>
                    </tfoot>
                {% endif %}
            </table>
        </div>
    </div>
</section>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3" id="other-issue-review">
        <div>
            <p class="eyebrow mb-1">PM Queue</p>
            <h2 class="h3 mb-0">Other Issues</h2>
        </div>
        <div class="status-code-pill {{ 'status-warning' if support_data.support_cards.other_issue_requests else 'status-success' }}">
            {{ support_data.support_cards.other_issue_requests }} pending
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="table-responsive table-scroll">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Queue Ticket</th>
                        <th>Requester</th>
                        <th>Context</th>
                        <th>Device</th>
                        <th>Issue description</th>
                        <th>Uploaded file</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in support_data.other_issue_rows %}
                        <tr class="{% if row.request.is_escalated %}ticket-row-escalated{% endif %}">
                            <td>
                                <div class="fw-semibold">{{ row.request.queue_ticket_number }}</div>
                                <div class="text-secondary small">{{ row.request.created_at|india_datetime }}</div>
                                {% if row.request.is_escalated %}
                                    <div class="mt-1"><span class="status-code-pill status-danger">High Priority / Escalated</span></div>
                                {% endif %}
                            </td>
                            <td>
                                <div>{{ row.request.requester_name or 'Not provided' }}</div>
                                <div class="text-secondary small">{{ row.request.requester_email or 'Email not provided' }}</div>
                                <div class="text-secondary small">{{ row.request.requester_number or 'Phone not provided' }}</div>
                            </td>
                            <td>
                                {{ row.request.source_system or 'Not provided' }}
                                <div class="text-secondary small">{{ row.request.user_type.replace('_', ' ').title() }}</div>
                                <div class="text-secondary small">Flow: {{ row.request.source_flow or 'General support' }}</div>
                                <div class="text-secondary small">Page: {{ row.request.page_label or 'Not specified' }}</div>
                                <div class="text-secondary small">Section: {{ row.request.section_label or 'Not specified' }}</div>
                                <div class="text-secondary small">Screen: {{ row.request.screen_label or 'Not specified' }}</div>
                            </td>
                            <td>
                                <div>{{ row.request.get_device_type_display() if row.request.device_type else 'Not provided' }}</div>
                                <div class="text-secondary small">{{ row.request.get_device_display() if row.request.device else 'Device not provided' }}</div>
                            </td>
                            <td>{{ row.request.free_text }}</td>
                            <td>
                                {% if row.request.uploaded_file %}
                                    <div class="d-flex flex-column gap-2 align-items-start">
                                        <a class="btn btn-sm btn-outline-secondary" href="{{ row.request.uploaded_file.url }}" target="_blank" rel="noreferrer">Open file</a>
                                        <span class="small text-secondary">{{ row.uploaded_file_name }}</span>
                                        {% if row.uploaded_file_is_image %}
                                            <img
                                                src="{{ row.request.uploaded_file.url }}"
                                                alt="Support evidence preview"
                                                class="rounded-3 border"
                                                style="width: 84px; height: 84px; object-fit: cover;"
                                            >
                                        {% endif %}
                                    </div>
                                {% else %}
                                    <span class="text-secondary">No file</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="d-flex flex-column align-items-start gap-2">
                                    <a class="btn btn-sm btn-primary" href="{{ row.raise_ticket_url }}">Raise Ticket</a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="7" class="text-secondary">No unlisted support issues are waiting for review.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3" id="critical-ticket-review">
        <div>
            <p class="eyebrow mb-1">Immediate Action</p>
            <h2 class="h3 mb-0">Critical Tickets</h2>
        </div>
        <a class="btn btn-outline-secondary" href="{{ url('ticketing:list') }}?scope=critical">Open critical queue</a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">
            <div class="insight-list card-scroll">
                {% for ticket in support_data.high_priority_tickets %}
                    <div class="insight-item {% if ticket.is_high_priority_escalated %}insight-item-escalated{% elif ticket.priority == 'critical' %}insight-item-critical{% elif ticket.priority == 'high' %}insight-item-high{% endif %}">
                        <div>
                            <div class="insight-item-title">{{ ticket.ticket_number }} · {{ ticket.title }}</div>
                            <div class="insight-item-subtitle">
                                {{ ticket.ticket_category.name if ticket.ticket_category else 'Uncategorized' }} ·
                                {{ ticket.department.name }} ·
                                {{ ticket.current_assignee.full_name or ticket.current_assignee.email }}
                            </div>
                            <div class="text-secondary small mt-2">
                                {{ ticket.requester_name }} · {{ ticket.requester_email }} · {{ ticket.requester_number or 'Phone not provided' }}
                            </div>
                        </div>
                        <div class="d-flex flex-column align-items-end gap-2">
                            {% if ticket.is_high_priority_escalated %}
                                <span class="status-code-pill status-danger">High Priority / Escalated</span>
                            {% endif %}
                            <span class="priority-pill {{ ticket.priority_badge_class }}">{{ ticket.get_priority_display() }}</span>
                            <span class="status-pill {{ ticket.status_badge_class }}">{{ ticket.get_status_display() }}</span>
                            <div class="insight-actions">
                                {% if ticket.priority == 'critical' and not ticket.is_high_priority_escalated %}
                                    <form method="post" action="{{ url('ticketing:escalate', pk=ticket.pk) }}">
                                        {{ csrf_input }}
                                        <input type="hidden" name="next" value="{{ url('dashboards:home') }}#critical-ticket-review">
                                        <button class="btn btn-sm btn-outline-danger" type="submit">Escalate</button>
                                    </form>
                                {% endif %}
                                <a class="btn btn-sm btn-primary" href="{{ url('ticketing:detail', pk=ticket.pk) }}">Open ticket</a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <p class="text-secondary mb-0">No urgent tickets are waiting right now.</p>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
        <div>
            <p class="eyebrow mb-1">Queue</p>
            <h2 class="h3 mb-0">Full Ticket Queue</h2>
        </div>
        <a class="btn btn-outline-secondary" href="{{ url('ticketing:list') }}">Open ticket list</a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="table-responsive table-scroll">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Ticket</th>
                        <th>Requester</th>
                        <th>Category</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Assignee</th>
                        <th>Age</th>
                    </tr>
                </thead>
                <tbody>
                    {% for ticket in support_data.overview_tickets %}
                        <tr class="{% if ticket.is_high_priority_escalated %}ticket-row-escalated{% elif ticket.priority == 'critical' %}ticket-row-critical{% elif ticket.priority == 'high' %}ticket-row-high{% endif %}">
                            <td>
                                <a class="fw-semibold text-decoration-none" href="{{ url('ticketing:detail', pk=ticket.pk) }}">{{ ticket.ticket_number }}</a>
                                <div class="text-secondary small">{{ ticket.title }}</div>
                                {% if ticket.is_high_priority_escalated %}
                                    <div class="mt-1"><span class="status-code-pill status-danger">High Priority / Escalated</span></div>
                                {% endif %}
                            </td>
                            <td>
                                <div>{{ ticket.requester_name }}</div>
                                <div class="text-secondary small">{{ ticket.requester_email }}</div>
                                <div class="text-secondary small">{{ ticket.requester_number or 'Phone not provided' }}</div>
                            </td>
                            <td>
                                {{ ticket.ticket_category.name if ticket.ticket_category else 'Uncategorized' }}
                                <div class="text-secondary small">{{ ticket.ticket_type }}</div>
                            </td>
                            <td><span class="priority-pill {{ ticket.priority_badge_class }}">{{ ticket.get_priority_display() }}</span></td>
                            <td><span class="status-pill {{ ticket.status_badge_class }}">{{ ticket.get_status_display() }}</span></td>
                            <td>{{ ticket.current_assignee.full_name or ticket.current_assignee.email }}</td>
                            <td>{{ ticket.ageing_days }} day{{ '' if ticket.ageing_days == 1 else 's' }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="7" class="p-4 text-secondary">No tickets are available for this view yet.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>

<section>
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
        <div>
            <p class="eyebrow mb-1">System Availability</p>
            <h2 class="h3 mb-0">System-wise and URL-wise status availability</h2>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-secondary" href="{{ url('reporting:contracts') }}">API field contracts</a>
            <a class="btn btn-outline-secondary" href="/admin/reporting/">Admin reporting data</a>
        </div>
    </div>

    <div class="status-grid mb-4">
        {% for row in status_data.systems %}
            <div class="status-summary-card">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <div class="eyebrow mb-2">System</div>
                        <h3 class="h5 mb-1">{{ row.system }}</h3>
                        <div class="text-secondary small">{{ row.total }} monitored URL{{ '' if row.total == 1 else 's' }}</div>
                    </div>
                    <span class="status-code-pill {{ 'status-danger' if row.critical else ('status-warning' if row.warning else ('status-info' if row.info else 'status-success')) }}">
                        {{ 'Attention needed' if row.critical else ('Redirects present' if row.info else 'Healthy') }}
                    </span>
                </div>
                <div class="status-summary-meta">
                    <span class="status-code-pill status-success">200/2xx: {{ row.ok }}</span>
                    <span class="status-code-pill status-info">3xx: {{ row.info }}</span>
                    <span class="status-code-pill status-warning">4xx: {{ row.warning }}</span>
                    <span class="status-code-pill status-danger">5xx / errors: {{ row.critical }}</span>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body border-bottom">
            <h3 class="h5 mb-1">URL-wise availability table</h3>
            <p class="text-secondary mb-0">This preserves system health visibility without crowding the ticket decision layer above.</p>
        </div>
        <div class="table-responsive table-scroll">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>System</th>
                        <th>Label</th>
                        <th>Status</th>
                        <th>URL</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in status_data.urls %}
                        <tr>
                            <td>{{ row.system }}</td>
                            <td>{{ row.label }}</td>
                            <td><span class="status-code-pill status-{{ row.variant }}">{{ row.status_code if row.status_code else 'Error' }}</span></td>
                            <td><a href="{{ row.url }}" target="_blank" rel="noreferrer">{{ row.url }}</a></td>
                            <td>{{ row.error_message or 'Available' }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="5" class="text-secondary">No status targets configured yet.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>

<script>
(() => {
    const chartPayload = {{ support_data.chart_data|tojson }};
    const visualizations = document.getElementById("dashboard-visualizations");
    const toggleButton = document.getElementById("toggle-visualizations");
    let chartsInitialized = false;

    function navigateOnClick(urls, elements) {
        if (!elements.length) {
            return;
        }
        const targetUrl = urls[elements[0].index];
        if (targetUrl) {
            window.location.href = targetUrl;
        }
    }

    function buildCharts() {
        if (chartsInitialized || !window.Chart) {
            return;
        }
        chartsInitialized = true;

        new Chart(document.getElementById("pm-category-chart"), {
            type: "bar",
            data: {
                labels: chartPayload.category.labels,
                datasets: [{
                    data: chartPayload.category.values,
                    backgroundColor: chartPayload.category.colors,
                    borderRadius: 10,
                }],
            },
            options: {
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { precision: 0 } },
                },
                onClick: (_event, elements) => navigateOnClick(chartPayload.category.urls, elements),
            },
        });

        new Chart(document.getElementById("pm-status-chart"), {
            type: "doughnut",
            data: {
                labels: chartPayload.status.labels,
                datasets: [{
                    data: chartPayload.status.values,
                    backgroundColor: chartPayload.status.colors,
                    borderWidth: 0,
                }],
            },
            options: {
                maintainAspectRatio: false,
                onClick: (_event, elements) => navigateOnClick(chartPayload.status.urls, elements),
            },
        });

        new Chart(document.getElementById("pm-priority-chart"), {
            type: "polarArea",
            data: {
                labels: chartPayload.priority.labels,
                datasets: [{
                    data: chartPayload.priority.values,
                    backgroundColor: chartPayload.priority.colors,
                    borderWidth: 0,
                }],
            },
            options: {
                maintainAspectRatio: false,
                onClick: (_event, elements) => navigateOnClick(chartPayload.priority.urls, elements),
            },
        });
    }

    if (!visualizations) {
        return;
    }

    visualizations.addEventListener("shown.bs.collapse", () => {
        buildCharts();
        if (toggleButton) {
            toggleButton.textContent = "Hide Visualizations";
        }
    });

    visualizations.addEventListener("hidden.bs.collapse", () => {
        if (toggleButton) {
            toggleButton.textContent = "View Visualizations";
        }
    });
})();
</script>
{% endblock %}
