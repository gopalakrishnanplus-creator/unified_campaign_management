{% extends "base.jinja" %}
{% block title %}Project Management Dashboard{% endblock %}
{% block extra_head %}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.0/dist/chart.umd.min.js"></script>
{% endblock %}
{% block content %}
<div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-3">
    <div>
        <p class="eyebrow mb-1">Project Management Dashboard</p>
        <h1 class="mb-0">Ticket and support command center</h1>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary" href="{{ url('dashboards:performance') }}">Campaign performance</a>
        <a class="btn btn-outline-secondary" href="{{ url('ticketing:distribution') }}">Ticket trends</a>
    </div>
</div>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
        <div>
            <p class="eyebrow mb-1">Ticket Overview</p>
            <h2 class="h3 mb-0">Decision-ready summary</h2>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button
                class="btn btn-outline-secondary"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#dashboard-visualizations"
                aria-expanded="false"
                aria-controls="dashboard-visualizations"
                id="toggle-visualizations"
            >
                View Visualizations
            </button>
            <a class="btn btn-outline-secondary" href="{{ url('ticketing:list') }}">Open full queue</a>
            <a class="btn btn-primary" href="{{ url('ticketing:create') }}">Create ticket</a>
        </div>
    </div>

    <div class="row g-2 mb-3">
        {% for card in support_data.overview_cards %}
            <div class="col-md-6 col-xl">
                <a class="metric-card metric-card-link h-100 text-decoration-none" href="{{ card.url }}">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <span class="metric-label">{{ card.label }}</span>
                        <span class="status-code-pill {{ card.badge_class }}">{{ card.badge }}</span>
                    </div>
                    <div class="metric-value">{{ card.value }}</div>
                    <div class="small text-secondary mt-2">{{ card.subtitle }}</div>
                </a>
            </div>
        {% endfor %}
    </div>

    <div class="collapse" id="dashboard-visualizations">
        <div class="row g-3">
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 h-100">
                    <div class="card-body">
                        <h3 class="h5 mb-3">Ticket distribution by category</h3>
                        <div class="chart-panel mb-3">
                            <canvas id="pm-category-chart"></canvas>
                        </div>
                        <div class="chart-legend-list">
                            {% for row in support_data.category_breakdown %}
                                <a class="chart-legend-item text-decoration-none text-reset" href="{{ row.url }}">
                                    <span class="chart-legend-swatch" style="background: {{ row.color }};"></span>
                                    <span class="chart-legend-label">{{ row.label }}</span>
                                    <strong>{{ row.count }}</strong>
                                </a>
                            {% else %}
                                <p class="text-secondary mb-0">No category data yet.</p>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 h-100">
                    <div class="card-body">
                        <h3 class="h5 mb-3">Status breakdown</h3>
                        <div class="chart-panel mb-3">
                            <canvas id="pm-status-chart"></canvas>
                        </div>
                        <div class="chart-legend-list">
                            {% for row in support_data.status_breakdown %}
                                <a class="chart-legend-item text-decoration-none text-reset" href="{{ row.url }}">
                                    <span class="status-pill {{ row.badge_class }}">{{ row.label }}</span>
                                    <strong>{{ row.count }}</strong>
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 h-100">
                    <div class="card-body">
                        <h3 class="h5 mb-3">Priority levels</h3>
                        <div class="chart-panel mb-3">
                            <canvas id="pm-priority-chart"></canvas>
                        </div>
                        <div class="chart-legend-list">
                            {% for row in support_data.priority_breakdown %}
                                <a class="chart-legend-item text-decoration-none text-reset" href="{{ row.url }}">
                                    <span class="priority-pill {{ row.badge_class }}">{{ row.label }}</span>
                                    <strong>{{ row.count }}</strong>
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
        <div>
            <p class="eyebrow mb-1">Widget Activity</p>
            <h2 class="h3 mb-0">System-wise support widget counts</h2>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>System</th>
                        <th>Widget Opened</th>
                        <th>Resolved</th>
                        <th>Send Ticket</th>
                        <th>PM Raised Ticket</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in support_data.widget_activity_rows %}
                        <tr>
                            <td class="fw-semibold">{{ row.system }}</td>
                            <td>{{ row.widget_open_count }}</td>
                            <td>{{ row.resolved_count }}</td>
                            <td>{{ row.send_ticket_count }}</td>
                            <td>{{ row.pm_raised_ticket_count }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="5" class="text-secondary">No widget activity recorded yet.</td></tr>
                    {% endfor %}
                </tbody>
                {% if support_data.widget_activity_rows %}
                    <tfoot>
                        <tr>
                            <th>Total</th>
                            <th>{{ support_data.widget_activity_totals.widget_open_count }}</th>
                            <th>{{ support_data.widget_activity_totals.resolved_count }}</th>
                            <th>{{ support_data.widget_activity_totals.send_ticket_count }}</th>
                            <th>{{ support_data.widget_activity_totals.pm_raised_ticket_count }}</th>
                        </tr>
                    </tfoot>
                {% endif %}
            </table>
        </div>
    </div>
</section>

<section class="mb-4" id="special-instruction-review">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
        <div>
            <p class="eyebrow mb-1">RFA Special Instructions</p>
            <h2 class="h3 mb-0">{{ 'Archived document approvals' if support_data.special_instruction_pagination.is_archived else 'Document approval queue' }}</h2>
        </div>
        <div class="status-code-pill {{ 'status-info' if support_data.special_instruction_pagination.is_archived else ('status-warning' if support_data.support_cards.special_instruction_reviews else 'status-success') }}">
            {{ support_data.special_instruction_pagination.archived_count if support_data.special_instruction_pagination.is_archived else support_data.support_cards.special_instruction_reviews }}
            {{ 'archived' if support_data.special_instruction_pagination.is_archived else 'active' }}
        </div>
    </div>

    <div class="d-flex gap-2 align-items-start flex-wrap mb-3">
        <details>
            <summary class="btn btn-sm btn-outline-secondary">Manual reload</summary>
            <form method="post" action="{{ url('dashboards:special_instruction_fetch') }}" class="row g-2 align-items-end mt-3">
                {{ csrf_input }}
                <div class="col-md-4">
                    <label class="form-label" for="special-instruction-doctor-id">Doctor ID</label>
                    <input class="form-control" id="special-instruction-doctor-id" name="doctor_id" placeholder="DOC401" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="special-instruction-campaign-id">Campaign ID</label>
                    <input class="form-control" id="special-instruction-campaign-id" name="campaign_id" placeholder="Optional campaign UUID">
                </div>
                <div class="col-md-auto">
                    <button class="btn btn-primary" type="submit">Reload ticket</button>
                </div>
            </form>
        </details>
        <button
            class="btn btn-sm btn-outline-secondary"
            type="button"
            data-bs-toggle="modal"
            data-bs-target="#special-instruction-archive-modal"
        >
            Archive
            <span class="badge text-bg-light ms-1">{{ support_data.support_cards.archived_special_instruction_reviews }}</span>
        </button>
    </div>

    {% if support_data.special_instruction_pagination.total_count %}
        <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap small text-secondary mb-3">
            <div>
                Showing {{ support_data.special_instruction_pagination.page_obj.start_index() }}-{{ support_data.special_instruction_pagination.page_obj.end_index() }}
                of {{ support_data.special_instruction_pagination.total_count }}
            </div>
            <div class="d-flex gap-2 align-items-center">
                {% if support_data.special_instruction_pagination.previous_url %}
                    <a class="btn btn-sm btn-outline-secondary" href="{{ support_data.special_instruction_pagination.previous_url }}">Previous</a>
                {% endif %}
                <span>Page {{ support_data.special_instruction_pagination.page_number }} of {{ support_data.special_instruction_pagination.num_pages }}</span>
                {% if support_data.special_instruction_pagination.next_url %}
                    <a class="btn btn-sm btn-outline-secondary" href="{{ support_data.special_instruction_pagination.next_url }}">Next</a>
                {% endif %}
            </div>
        </div>
    {% endif %}

    <div class="row g-3">
        {% for row in support_data.special_instruction_rows %}
            <div class="col-lg-6 col-xl-4">
                <div class="card shadow-sm border-0 rounded-4 h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between gap-2 align-items-start mb-3">
                            <div>
                                <p class="eyebrow mb-1">Doctor ID {{ row.review.doctor_id }}</p>
                                <h3 class="h5 mb-1">{{ row.review.doctor_name or 'Doctor not provided' }}</h3>
                                <div class="text-secondary small">{{ row.review.clinic_name or 'Clinic not provided' }}</div>
                            </div>
                            <div class="d-flex gap-2 align-items-start">
                                <span class="status-code-pill {{ row.workflow_badge }}">{{ row.workflow_label }}</span>
                                {% if support_data.special_instruction_pagination.is_archived %}
                                    <form method="post" action="{{ url('dashboards:special_instruction_archive', review_id=row.review.pk) }}">
                                        {{ csrf_input }}
                                        <input type="hidden" name="action" value="restore">
                                        <input type="hidden" name="next" value="{{ request.get_full_path() }}#special-instruction-review">
                                        <button class="status-code-pill status-secondary archive-action-pill" type="submit" title="Restore to queue">Restore</button>
                                    </form>
                                {% else %}
                                    <form method="post" action="{{ url('dashboards:special_instruction_archive', review_id=row.review.pk) }}">
                                        {{ csrf_input }}
                                        <input type="hidden" name="action" value="archive">
                                        <input type="hidden" name="next" value="{{ request.get_full_path() }}#special-instruction-review">
                                        <button class="status-code-pill status-secondary archive-action-pill" type="submit" title="Archive review">Archive</button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                        <div class="metric-row"><span>Campaign</span><strong>{{ row.review.campaign_name or 'Not provided' }}</strong></div>
                        <div class="metric-row"><span>Brand</span><strong>{{ row.review.brand_name or 'Not provided' }}</strong></div>
                        <div class="metric-row"><span>RFA status</span><strong>{{ row.review.rfa_current_status or 'Not provided' }}</strong></div>
                        <div class="metric-row"><span>Assignee</span><strong>{{ row.ticket.current_assignee.full_name or row.ticket.current_assignee.email }}</strong></div>
                        <div class="metric-row"><span>Approved</span><strong>{{ row.review.approved_at|india_datetime if row.review.approved_at else 'Pending' }}</strong></div>
                        <div class="metric-row"><span>Updated</span><strong>{{ row.workflow_at|india_datetime if row.workflow_at else 'Not available' }}</strong></div>
                        {% if support_data.special_instruction_pagination.is_archived %}
                            <div class="metric-row"><span>Archived</span><strong>{{ row.review.archived_at|india_datetime if row.review.archived_at else 'Not available' }}</strong></div>
                        {% endif %}
                        <a class="btn btn-sm btn-primary mt-3" href="{{ row.action_url }}">{{ row.action_label }}</a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body text-secondary">{{ 'No archived Special Instruction reviews yet.' if support_data.special_instruction_pagination.is_archived else 'No Special Instruction reviews have arrived from RFA yet.' }}</div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="modal fade special-instruction-archive-modal" id="special-instruction-archive-modal" tabindex="-1" aria-labelledby="special-instruction-archive-modal-title" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header align-items-start">
                    <div>
                        <p class="eyebrow mb-1">RFA Special Instructions</p>
                        <h2 class="modal-title fs-5" id="special-instruction-archive-modal-title">Archived document approvals</h2>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="status-code-pill status-info">{{ support_data.support_cards.archived_special_instruction_reviews }} archived</span>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                </div>
                <div class="modal-body">
                    <div class="special-instruction-archive-search mb-3">
                        <label class="form-label" for="special-instruction-archive-search">Search archived entries</label>
                        <input
                            class="form-control"
                            id="special-instruction-archive-search"
                            type="search"
                            placeholder="Search by Doctor Name or Doctor ID"
                            autocomplete="off"
                            data-special-instruction-archive-search
                        >
                        <div class="small text-secondary mt-2">
                            <span id="special-instruction-archive-match-count">{{ support_data.special_instruction_archive_rows|length }}</span>
                            matching archived cards
                        </div>
                    </div>

                    <div class="row g-3" id="special-instruction-archive-results">
                        {% for row in support_data.special_instruction_archive_rows %}
                            <div
                                class="col-md-6 special-instruction-archive-card"
                                data-special-instruction-archive-card
                                data-special-instruction-archive-search-text="{{ row.review.doctor_id }} {{ row.review.doctor_name or '' }}"
                            >
                                <div class="card shadow-sm border-0 rounded-4 h-100">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between gap-2 align-items-start mb-3">
                                            <div>
                                                <p class="eyebrow mb-1">Doctor ID {{ row.review.doctor_id }}</p>
                                                <h3 class="h5 mb-1">{{ row.review.doctor_name or 'Doctor not provided' }}</h3>
                                                <div class="text-secondary small">{{ row.review.clinic_name or 'Clinic not provided' }}</div>
                                            </div>
                                            <div class="d-flex gap-2 align-items-start">
                                                <span class="status-code-pill {{ row.workflow_badge }}">{{ row.workflow_label }}</span>
                                                <form method="post" action="{{ url('dashboards:special_instruction_archive', review_id=row.review.pk) }}">
                                                    {{ csrf_input }}
                                                    <input type="hidden" name="action" value="restore">
                                                    <input type="hidden" name="next" value="{{ request.get_full_path() }}#special-instruction-review">
                                                    <button class="status-code-pill status-secondary archive-action-pill" type="submit" title="Restore to queue">Restore</button>
                                                </form>
                                            </div>
                                        </div>
                                        <div class="metric-row"><span>Campaign</span><strong>{{ row.review.campaign_name or 'Not provided' }}</strong></div>
                                        <div class="metric-row"><span>Brand</span><strong>{{ row.review.brand_name or 'Not provided' }}</strong></div>
                                        <div class="metric-row"><span>RFA status</span><strong>{{ row.review.rfa_current_status or 'Not provided' }}</strong></div>
                                        <div class="metric-row"><span>Assignee</span><strong>{{ row.ticket.current_assignee.full_name or row.ticket.current_assignee.email }}</strong></div>
                                        <div class="metric-row"><span>Approved</span><strong>{{ row.review.approved_at|india_datetime if row.review.approved_at else 'Pending' }}</strong></div>
                                        <div class="metric-row"><span>Archived</span><strong>{{ row.review.archived_at|india_datetime if row.review.archived_at else 'Not available' }}</strong></div>
                                        <a class="btn btn-sm btn-primary mt-3" href="{{ row.action_url }}">{{ row.action_label }}</a>
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="col-12">
                                <div class="alert alert-light border mb-0">No archived Special Instruction reviews yet.</div>
                            </div>
                        {% endfor %}
                    </div>

                    <div class="alert alert-light border d-none mt-3 mb-0" id="special-instruction-archive-no-results">
                        No archived cards match this search.
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3" id="whatsapp-channel-review">
        <div>
            <p class="eyebrow mb-1">PM Queue</p>
            <h2 class="h3 mb-0">WhatsApp Channel Queries</h2>
        </div>
        <div class="status-code-pill {{ 'status-warning' if support_data.support_cards.whatsapp_channel_requests else 'status-success' }}">
            {{ support_data.support_cards.whatsapp_channel_requests }} pending
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="table-responsive table-scroll">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Queue Ticket</th>
                        <th>Doctor</th>
                        <th>Channel</th>
                        <th>Query</th>
                        <th>Uploaded images</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in support_data.whatsapp_channel_rows %}
                        <tr>
                            <td>
                                <div class="fw-semibold">{{ row.request.queue_ticket_number }}</div>
                                <div class="text-secondary small">{{ row.request.created_at|india_datetime }}</div>
                            </td>
                            <td>
                                <div>{{ row.request.requester_name or 'Not provided' }}</div>
                                <div class="text-secondary small">{{ row.request.requester_email or 'Email not provided' }}</div>
                                <div class="text-secondary small">{{ row.request.requester_number or 'Phone not provided' }}</div>
                            </td>
                            <td>
                                <span class="status-code-pill status-info">{{ row.request.get_whatsapp_channel_display() }}</span>
                                <div class="text-secondary small mt-1">{{ row.request.source_system or 'Not provided' }}</div>
                            </td>
                            <td>
                                {{ row.request.free_text }}
                            </td>
                            <td>
                                {% if row.uploaded_images %}
                                    <div class="d-flex flex-column gap-2 align-items-start">
                                        {% for image in row.uploaded_images %}
                                            <a class="btn btn-sm btn-outline-secondary" href="{{ image.file.url }}" target="_blank" rel="noreferrer">Open image {{ loop.index }}</a>
                                            <span class="small text-secondary">{{ image.file_name }}</span>
                                            <img
                                                src="{{ image.file.url }}"
                                                alt="WhatsApp query evidence preview"
                                                class="rounded-3 border"
                                                style="width: 84px; height: 84px; object-fit: cover;"
                                            >
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <span class="text-secondary">No images</span>
                                {% endif %}
                            </td>
                            <td>
                                <button
                                    class="btn btn-sm btn-primary"
                                    type="button"
                                    data-bs-toggle="modal"
                                    data-bs-target="#whatsapp-channel-approve-modal"
                                    data-approve-url="{{ row.approve_url }}"
                                    data-ticket="{{ row.request.queue_ticket_number }}"
                                    data-channel="{{ row.request.get_whatsapp_channel_display() }}"
                                    data-doctor="{{ row.request.requester_name or 'Not provided' }}"
                                    data-query="{{ row.request.free_text }}"
                                >
                                    View and approve
                                </button>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="6" class="text-secondary">No WhatsApp Channel queries are waiting for review.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="modal fade" id="whatsapp-channel-approve-modal" tabindex="-1" aria-labelledby="whatsapp-channel-approve-title" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header align-items-start">
                    <div>
                        <p class="eyebrow mb-1" id="whatsapp-channel-approve-ticket">WhatsApp Channel</p>
                        <h2 class="modal-title fs-5" id="whatsapp-channel-approve-title">Review query</h2>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form method="post" id="whatsapp-channel-approve-form" target="_blank">
                    <div class="modal-body">
                        {{ csrf_input }}
                        <div class="mb-3">
                            <div class="metric-row"><span>Channel</span><strong id="whatsapp-channel-approve-channel">Not provided</strong></div>
                            <div class="metric-row"><span>Doctor</span><strong id="whatsapp-channel-approve-doctor">Not provided</strong></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="whatsapp-channel-approve-query">Doctor query</label>
                            <textarea class="form-control" id="whatsapp-channel-approve-query" rows="4" readonly></textarea>
                        </div>
                        <div>
                            <label class="form-label" for="whatsapp-channel-response">Message / solution</label>
                            <textarea class="form-control" id="whatsapp-channel-response" name="moderator_response" rows="5" required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                        <button class="btn btn-primary" type="submit">Approve and open WhatsApp</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3" id="other-issue-review">
        <div>
            <p class="eyebrow mb-1">PM Queue</p>
            <h2 class="h3 mb-0">Other Issues</h2>
        </div>
        <div class="status-code-pill {{ 'status-warning' if support_data.support_cards.other_issue_requests else 'status-success' }}">
            {{ support_data.support_cards.other_issue_requests }} pending
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="table-responsive table-scroll">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Queue Ticket</th>
                        <th>Requester</th>
                        <th>Context</th>
                        <th>Device</th>
                        <th>Issue description</th>
                        <th>Uploaded file</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in support_data.other_issue_rows %}
                        <tr class="{% if row.request.is_escalated %}ticket-row-escalated{% endif %}">
                            <td>
                                <div class="fw-semibold">{{ row.request.queue_ticket_number }}</div>
                                <div class="text-secondary small">{{ row.request.created_at|india_datetime }}</div>
                                {% if row.request.is_escalated %}
                                    <div class="mt-1"><span class="status-code-pill status-danger">High Priority / Escalated</span></div>
                                {% endif %}
                            </td>
                            <td>
                                <div>{{ row.request.requester_name or 'Not provided' }}</div>
                                {% if row.request.doctor_id %}
                                    <div class="text-secondary small">Doctor ID {{ row.request.doctor_id }}</div>
                                {% endif %}
                                <div class="text-secondary small">{{ row.request.requester_email or 'Email not provided' }}</div>
                                <div class="text-secondary small">{{ row.request.requester_number or 'Phone not provided' }}</div>
                            </td>
                            <td>
                                {{ row.request.source_system or 'Not provided' }}
                                <div class="text-secondary small">{{ row.request.user_type.replace('_', ' ').title() }}</div>
                                <div class="text-secondary small">Flow: {{ row.request.source_flow or 'General support' }}</div>
                                <div class="text-secondary small">Page: {{ row.request.page_label or 'Not specified' }}</div>
                                <div class="text-secondary small">Section: {{ row.request.section_label or 'Not specified' }}</div>
                                <div class="text-secondary small">Screen: {{ row.request.screen_label or 'Not specified' }}</div>
                            </td>
                            <td>
                                <div>{{ row.request.get_device_type_display() if row.request.device_type else 'Not provided' }}</div>
                                <div class="text-secondary small">{{ row.request.get_device_display() if row.request.device else 'Device not provided' }}</div>
                            </td>
                            <td>{{ row.request.free_text }}</td>
                            <td>
                                {% if row.request.uploaded_file %}
                                    <div class="d-flex flex-column gap-2 align-items-start">
                                        <a class="btn btn-sm btn-outline-secondary" href="{{ row.request.uploaded_file.url }}" target="_blank" rel="noreferrer">Open file</a>
                                        <span class="small text-secondary">{{ row.uploaded_file_name }}</span>
                                        {% if row.uploaded_file_is_image %}
                                            <img
                                                src="{{ row.request.uploaded_file.url }}"
                                                alt="Support evidence preview"
                                                class="rounded-3 border"
                                                style="width: 84px; height: 84px; object-fit: cover;"
                                            >
                                        {% endif %}
                                    </div>
                                {% else %}
                                    <span class="text-secondary">No file</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="d-flex flex-column align-items-start gap-2">
                                    <a class="btn btn-sm btn-primary" href="{{ row.raise_ticket_url }}">Raise Ticket</a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="7" class="text-secondary">No unlisted support issues are waiting for review.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3" id="critical-ticket-review">
        <div>
            <p class="eyebrow mb-1">Immediate Action</p>
            <h2 class="h3 mb-0">Critical Tickets</h2>
        </div>
        <a class="btn btn-outline-secondary" href="{{ url('ticketing:list') }}?scope=critical">Open critical queue</a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">
            <div class="insight-list card-scroll">
                {% for ticket in support_data.high_priority_tickets %}
                    <div class="insight-item {% if ticket.is_high_priority_escalated %}insight-item-escalated{% elif ticket.priority == 'critical' %}insight-item-critical{% elif ticket.priority == 'high' %}insight-item-high{% endif %}">
                        <div>
                            <div class="insight-item-title">{{ ticket.ticket_number }} · {{ ticket.title }}</div>
                            <div class="insight-item-subtitle">
                                {{ ticket.ticket_category.name if ticket.ticket_category else 'Uncategorized' }} ·
                                {{ ticket.department.name }} ·
                                {{ ticket.current_assignee.full_name or ticket.current_assignee.email }}
                            </div>
                            <div class="text-secondary small mt-2">
                                {{ ticket.requester_name }} · {{ ticket.requester_email }} · {{ ticket.requester_number or 'Phone not provided' }}
                            </div>
                        </div>
                        <div class="d-flex flex-column align-items-end gap-2">
                            {% if ticket.is_high_priority_escalated %}
                                <span class="status-code-pill status-danger">High Priority / Escalated</span>
                            {% endif %}
                            <span class="priority-pill {{ ticket.priority_badge_class }}">{{ ticket.get_priority_display() }}</span>
                            <span class="status-pill {{ ticket.status_badge_class }}">{{ ticket.get_status_display() }}</span>
                            <div class="insight-actions">
                                {% if ticket.priority == 'critical' and not ticket.is_high_priority_escalated %}
                                    <form method="post" action="{{ url('ticketing:escalate', pk=ticket.pk) }}">
                                        {{ csrf_input }}
                                        <input type="hidden" name="next" value="{{ url('dashboards:home') }}#critical-ticket-review">
                                        <button class="btn btn-sm btn-outline-danger" type="submit">Escalate</button>
                                    </form>
                                {% endif %}
                                <a class="btn btn-sm btn-primary" href="{{ url('ticketing:detail', pk=ticket.pk) }}">Open ticket</a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <p class="text-secondary mb-0">No urgent tickets are waiting right now.</p>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
        <div>
            <p class="eyebrow mb-1">Queue</p>
            <h2 class="h3 mb-0">Full Ticket Queue</h2>
        </div>
        <a class="btn btn-outline-secondary" href="{{ url('ticketing:list') }}">Open ticket list</a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="table-responsive table-scroll">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Ticket</th>
                        <th>Requester</th>
                        <th>Category</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Assignee</th>
                        <th>Age</th>
                    </tr>
                </thead>
                <tbody>
                    {% for ticket in support_data.overview_tickets %}
                        <tr class="{% if ticket.is_high_priority_escalated %}ticket-row-escalated{% elif ticket.priority == 'critical' %}ticket-row-critical{% elif ticket.priority == 'high' %}ticket-row-high{% endif %}">
                            <td>
                                <a class="fw-semibold text-decoration-none" href="{{ url('ticketing:detail', pk=ticket.pk) }}">{{ ticket.ticket_number }}</a>
                                <div class="text-secondary small">{{ ticket.title }}</div>
                                {% if ticket.is_high_priority_escalated %}
                                    <div class="mt-1"><span class="status-code-pill status-danger">High Priority / Escalated</span></div>
                                {% endif %}
                            </td>
                            <td>
                                <div>{{ ticket.requester_name }}</div>
                                <div class="text-secondary small">{{ ticket.requester_email }}</div>
                                <div class="text-secondary small">{{ ticket.requester_number or 'Phone not provided' }}</div>
                            </td>
                            <td>
                                {{ ticket.ticket_category.name if ticket.ticket_category else 'Uncategorized' }}
                                <div class="text-secondary small">{{ ticket.ticket_type }}</div>
                            </td>
                            <td><span class="priority-pill {{ ticket.priority_badge_class }}">{{ ticket.get_priority_display() }}</span></td>
                            <td><span class="status-pill {{ ticket.status_badge_class }}">{{ ticket.get_status_display() }}</span></td>
                            <td>{{ ticket.current_assignee.full_name or ticket.current_assignee.email }}</td>
                            <td>{{ ticket.ageing_days }} day{{ '' if ticket.ageing_days == 1 else 's' }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="7" class="p-4 text-secondary">No tickets are available for this view yet.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>

<section>
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
        <div>
            <p class="eyebrow mb-1">System Availability</p>
            <h2 class="h3 mb-0">System-wise and URL-wise status availability</h2>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-secondary" href="{{ url('reporting:contracts') }}">API field contracts</a>
            <a class="btn btn-outline-secondary" href="/admin/reporting/">Admin reporting data</a>
        </div>
    </div>

    <div class="status-grid mb-4">
        {% for row in status_data.systems %}
            <div class="status-summary-card">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <div class="eyebrow mb-2">System</div>
                        <h3 class="h5 mb-1">{{ row.system }}</h3>
                        <div class="text-secondary small">{{ row.total }} monitored URL{{ '' if row.total == 1 else 's' }}</div>
                    </div>
                    <span class="status-code-pill {{ 'status-danger' if row.critical else ('status-warning' if row.warning else ('status-info' if row.info else 'status-success')) }}">
                        {{ 'Attention needed' if row.critical else ('Redirects present' if row.info else 'Healthy') }}
                    </span>
                </div>
                <div class="status-summary-meta">
                    <span class="status-code-pill status-success">200/2xx: {{ row.ok }}</span>
                    <span class="status-code-pill status-info">3xx: {{ row.info }}</span>
                    <span class="status-code-pill status-warning">4xx: {{ row.warning }}</span>
                    <span class="status-code-pill status-danger">5xx / errors: {{ row.critical }}</span>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body border-bottom">
            <h3 class="h5 mb-1">URL-wise availability table</h3>
            <p class="text-secondary mb-0">This preserves system health visibility without crowding the ticket decision layer above.</p>
        </div>
        <div class="table-responsive table-scroll">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>System</th>
                        <th>Label</th>
                        <th>Status</th>
                        <th>URL</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in status_data.urls %}
                        <tr>
                            <td>{{ row.system }}</td>
                            <td>{{ row.label }}</td>
                            <td><span class="status-code-pill status-{{ row.variant }}">{{ row.status_code if row.status_code else 'Error' }}</span></td>
                            <td><a href="{{ row.url }}" target="_blank" rel="noreferrer">{{ row.url }}</a></td>
                            <td>{{ row.error_message or 'Available' }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="5" class="text-secondary">No status targets configured yet.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>

<script>
(() => {
    const chartPayload = {{ support_data.chart_data|tojson }};
    const visualizations = document.getElementById("dashboard-visualizations");
    const toggleButton = document.getElementById("toggle-visualizations");
    const archiveModal = document.getElementById("special-instruction-archive-modal");
    const archiveSearch = document.getElementById("special-instruction-archive-search");
    const archiveCards = Array.from(document.querySelectorAll("[data-special-instruction-archive-card]"));
    const archiveEmptySearch = document.getElementById("special-instruction-archive-no-results");
    const archiveMatchCount = document.getElementById("special-instruction-archive-match-count");
    const whatsappApproveModal = document.getElementById("whatsapp-channel-approve-modal");
    const whatsappApproveForm = document.getElementById("whatsapp-channel-approve-form");
    const whatsappApproveTicket = document.getElementById("whatsapp-channel-approve-ticket");
    const whatsappApproveTitle = document.getElementById("whatsapp-channel-approve-title");
    const whatsappApproveChannel = document.getElementById("whatsapp-channel-approve-channel");
    const whatsappApproveDoctor = document.getElementById("whatsapp-channel-approve-doctor");
    const whatsappApproveQuery = document.getElementById("whatsapp-channel-approve-query");
    const whatsappApproveResponse = document.getElementById("whatsapp-channel-response");
    let chartsInitialized = false;

    function filterArchivedCards() {
        if (!archiveSearch) {
            return;
        }
        const query = archiveSearch.value.trim().toLowerCase();
        let visibleCount = 0;
        archiveCards.forEach((card) => {
            const searchText = (card.dataset.specialInstructionArchiveSearchText || "").toLowerCase();
            const isVisible = !query || searchText.includes(query);
            card.classList.toggle("d-none", !isVisible);
            if (isVisible) {
                visibleCount += 1;
            }
        });
        if (archiveMatchCount) {
            archiveMatchCount.textContent = visibleCount;
        }
        if (archiveEmptySearch) {
            archiveEmptySearch.classList.toggle("d-none", visibleCount !== 0 || archiveCards.length === 0);
        }
    }

    if (archiveSearch) {
        archiveSearch.addEventListener("input", filterArchivedCards);
        filterArchivedCards();
    }

    if (archiveModal && archiveSearch) {
        archiveModal.addEventListener("shown.bs.modal", () => {
            archiveSearch.focus();
            filterArchivedCards();
        });
    }

    if (whatsappApproveModal && whatsappApproveForm) {
        whatsappApproveModal.addEventListener("show.bs.modal", (event) => {
            const trigger = event.relatedTarget;
            if (!trigger) {
                return;
            }
            whatsappApproveForm.action = trigger.dataset.approveUrl || "";
            if (whatsappApproveTicket) {
                whatsappApproveTicket.textContent = trigger.dataset.ticket || "WhatsApp Channel";
            }
            if (whatsappApproveTitle) {
                whatsappApproveTitle.textContent = `Review ${trigger.dataset.channel || "WhatsApp"} query`;
            }
            if (whatsappApproveChannel) {
                whatsappApproveChannel.textContent = trigger.dataset.channel || "Not provided";
            }
            if (whatsappApproveDoctor) {
                whatsappApproveDoctor.textContent = trigger.dataset.doctor || "Not provided";
            }
            if (whatsappApproveQuery) {
                whatsappApproveQuery.value = trigger.dataset.query || "";
            }
            if (whatsappApproveResponse) {
                whatsappApproveResponse.value = "";
            }
        });
    }

    function navigateOnClick(urls, elements) {
        if (!elements.length) {
            return;
        }
        const targetUrl = urls[elements[0].index];
        if (targetUrl) {
            window.location.href = targetUrl;
        }
    }

    function buildCharts() {
        if (chartsInitialized || !window.Chart) {
            return;
        }
        chartsInitialized = true;

        new Chart(document.getElementById("pm-category-chart"), {
            type: "bar",
            data: {
                labels: chartPayload.category.labels,
                datasets: [{
                    data: chartPayload.category.values,
                    backgroundColor: chartPayload.category.colors,
                    borderRadius: 10,
                }],
            },
            options: {
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { precision: 0 } },
                },
                onClick: (_event, elements) => navigateOnClick(chartPayload.category.urls, elements),
            },
        });

        new Chart(document.getElementById("pm-status-chart"), {
            type: "doughnut",
            data: {
                labels: chartPayload.status.labels,
                datasets: [{
                    data: chartPayload.status.values,
                    backgroundColor: chartPayload.status.colors,
                    borderWidth: 0,
                }],
            },
            options: {
                maintainAspectRatio: false,
                onClick: (_event, elements) => navigateOnClick(chartPayload.status.urls, elements),
            },
        });

        new Chart(document.getElementById("pm-priority-chart"), {
            type: "polarArea",
            data: {
                labels: chartPayload.priority.labels,
                datasets: [{
                    data: chartPayload.priority.values,
                    backgroundColor: chartPayload.priority.colors,
                    borderWidth: 0,
                }],
            },
            options: {
                maintainAspectRatio: false,
                onClick: (_event, elements) => navigateOnClick(chartPayload.priority.urls, elements),
            },
        });
    }

    if (!visualizations) {
        return;
    }

    visualizations.addEventListener("shown.bs.collapse", () => {
        buildCharts();
        if (toggleButton) {
            toggleButton.textContent = "Hide Visualizations";
        }
    });

    visualizations.addEventListener("hidden.bs.collapse", () => {
        if (toggleButton) {
            toggleButton.textContent = "View Visualizations";
        }
    });
})();
</script>
{% endblock %}
