<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>WhatsApp Channel Query</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ static('css/app.css') }}">
</head>
<body>
    <main class="pb-5">
        <div class="container py-4">
            <div class="col-lg-8 mx-auto">
                {% if messages %}
                    <div class="mb-3">
                        {% for message in messages %}
                            <div class="alert alert-{{ message.tags or 'info' }}">{{ message }}</div>
                        {% endfor %}
                    </div>
                {% endif %}

                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body p-4 p-lg-5">
                        {% if form.non_field_errors() %}
                            <div class="alert alert-danger rounded-4">{{ form.non_field_errors()|join(', ') }}</div>
                        {% endif %}

                        <form method="post" enctype="multipart/form-data" novalidate>
                            {{ csrf_input }}
                            <input type="hidden" name="whatsapp_channel" value="{{ whatsapp_channel }}">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label" for="{{ form.requester_name.id_for_label }}">{{ form.requester_name.label }}</label>
                                    {{ form.requester_name }}
                                    {% if form.requester_name.errors %}<div class="text-danger small mt-1">{{ form.requester_name.errors|join(', ') }}</div>{% endif %}
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="{{ form.requester_number.id_for_label }}">{{ form.requester_number.label }}</label>
                                    {{ form.requester_number }}
                                    {% if form.requester_number.errors %}<div class="text-danger small mt-1">{{ form.requester_number.errors|join(', ') }}</div>{% endif %}
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="{{ form.requester_email.id_for_label }}">{{ form.requester_email.label }}</label>
                                    {{ form.requester_email }}
                                    {% if form.requester_email.errors %}<div class="text-danger small mt-1">{{ form.requester_email.errors|join(', ') }}</div>{% endif %}
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="{{ form.free_text.id_for_label }}">{{ form.free_text.label }}</label>
                                    {{ form.free_text }}
                                    {% if form.free_text.errors %}<div class="text-danger small mt-1">{{ form.free_text.errors|join(', ') }}</div>{% endif %}
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="{{ form.images.id_for_label }}">{{ form.images.label }}</label>
                                    {{ form.images }}
                                    <div class="form-text">Upload up to 5 images.</div>
                                    {% if form.images.errors %}<div class="text-danger small mt-1">{{ form.images.errors|join(', ') }}</div>{% endif %}
                                </div>
                            </div>

                            <div class="mt-4">
                                <button class="btn btn-primary" type="submit">Submit for review</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
