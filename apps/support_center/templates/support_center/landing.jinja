{% extends "base.jinja" %}
{% block title %}{{ role_title }}{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-end gap-3 flex-wrap mb-4">
    <div>
        <p class="eyebrow mb-1">{{ role_title }}</p>
        <h1 class="mb-1">{{ page_title }}</h1>
        <p class="text-secondary mb-0">FAQs are organized page-wise and section-wise so users can stay inside the built-in support flow without filling extra support request forms.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary" href="{{ faq_links_api_url }}" target="_blank">FAQ links API</a>
        <a class="btn btn-outline-primary" href="{{ url('support_center:assistant', user_type=user_type) }}">Guided assistant</a>
        {% if request.user.is_authenticated %}
            <a class="btn btn-outline-primary" href="{{ url('ticketing:list') }}">Internal ticket queue</a>
        {% endif %}
    </div>
</div>

<div class="row g-4">
    <div class="col-12">
        {% for block in faq_pages %}
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
                        <div>
                            <h2 class="h4 mb-2">{{ block.page.name }}</h2>
                            <p class="text-secondary mb-2">{{ block.section_count }} sections · {{ block.faq_count }} FAQs</p>
                            <div class="small text-secondary">{{ block.section_names|join(' • ') }}</div>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <a class="btn btn-primary" href="{{ url('support_center:faq_page', user_type=user_type, page_slug=block.page.slug) }}">Open page</a>
                            <a class="btn btn-outline-secondary" href="{{ block.widget_url }}" target="_blank" rel="noreferrer">Standalone widget</a>
                        </div>
                    </div>
                    <div class="row g-3">
                        {% for section in block.sections %}
                            <div class="col-md-6 col-xl-4">
                                <div class="border rounded-4 p-3 h-100 bg-light-subtle">
                                    <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                        <strong>{{ section.name }}</strong>
                                        <span class="badge text-bg-light">{{ section.faq_count }} FAQs</span>
                                    </div>
                                    {% if section.category_names %}
                                        <div class="small text-secondary">{{ section.category_names|join(' • ') }}</div>
                                    {% else %}
                                        <div class="small text-secondary">Page section</div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="alert alert-warning rounded-4">No active FAQ pages are available for this audience yet.</div>
        {% endfor %}
    </div>
</div>
{% endblock %}
