{% extends "base.jinja" %}
{% block title %}{{ role_title }}{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-end gap-3 flex-wrap mb-4">
    <div>
        <p class="eyebrow mb-1">{{ role_title }}</p>
        <h1 class="mb-1">{{ page_title }}</h1>
        <p class="text-secondary mb-0">FAQs are now organized page-wise. Open a page to review its sections and launch the page-specific support widget.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary" href="{{ faq_links_api_url }}" target="_blank">FAQ links API</a>
        {% if request.user.is_authenticated %}
            <a class="btn btn-outline-primary" href="{{ url('ticketing:list') }}">Internal ticket queue</a>
        {% endif %}
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        {% for block in faq_pages %}
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                        <div>
                            <h2 class="h4 mb-2">{{ block.page.name }}</h2>
                            <p class="text-secondary mb-2">{{ block.section_count }} sections · {{ block.faq_count }} FAQs</p>
                            <div class="small text-secondary">{{ block.section_names|join(' • ') }}</div>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <a class="btn btn-primary" href="{{ url('support_center:faq_page', user_type=user_type, page_slug=block.page.slug) }}">Open page</a>
                            <a class="btn btn-outline-secondary" href="{{ block.widget_url }}" target="_blank" rel="noreferrer">Standalone widget</a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="alert alert-warning rounded-4">No active FAQ pages are available for this audience yet.</div>
        {% endfor %}
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Free-text support request</h2>
                <form method="post" class="vstack gap-3">
                    {{ csrf_input }}
                    {% for field in free_text_form %}
                        <div>
                            <label class="form-label" for="{{ field.id_for_label }}">{{ field.label }}</label>
                            {{ field }}
                            {% if field.errors %}<div class="text-danger small mt-1">{{ field.errors|join(', ') }}</div>{% endif %}
                        </div>
                    {% endfor %}
                    <button class="btn btn-primary" type="submit">Raise support ticket</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
