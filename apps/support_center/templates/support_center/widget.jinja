<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title }}</title>
    <link rel="icon" href="data:,">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --faq-accent: #0f766e;
            --faq-accent-2: #1d4ed8;
            --faq-ink: #0f172a;
            --faq-muted: #64748b;
            --faq-surface: #f8fafc;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(180deg, #f8fafc, #ffffff);
            color: var(--faq-ink);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        .widget-shell {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .widget-header {
            padding: 1rem 1.25rem;
            background: linear-gradient(135deg, var(--faq-accent), var(--faq-accent-2));
            color: white;
        }

        .widget-header p {
            margin: 0;
            opacity: 0.88;
            font-size: 0.85rem;
        }

        .widget-body {
            padding: 1rem;
            display: grid;
            gap: 1rem;
            flex: 1;
            background: var(--faq-surface);
        }

        .transcript {
            display: grid;
            gap: 0.75rem;
            max-height: 34vh;
            overflow-y: auto;
            padding-right: 0.25rem;
        }

        .bubble-row {
            display: flex;
        }

        .bubble-row-user {
            justify-content: flex-end;
        }

        .bubble {
            max-width: 94%;
            border-radius: 1rem;
            padding: 0.85rem 1rem;
            border: 1px solid rgba(15, 23, 42, 0.08);
            background: white;
            box-shadow: 0 10px 20px rgba(15, 23, 42, 0.05);
        }

        .bubble-row-user .bubble {
            background: rgba(29, 78, 216, 0.08);
        }

        .bubble-label {
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--faq-accent);
            margin-bottom: 0.3rem;
        }

        .menu-list,
        .question-list {
            display: grid;
            gap: 0.75rem;
        }

        .question-option {
            border: 1px solid rgba(15, 23, 42, 0.08);
            border-radius: 1rem;
            background: white;
            padding: 0.85rem 1rem;
        }

        .question-meta {
            display: block;
            margin-top: 0.2rem;
            color: var(--faq-muted);
            font-size: 0.82rem;
        }

        .support-link-list {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-top: 0.75rem;
        }

        .widget-footer {
            padding: 0 1rem 1rem;
            color: var(--faq-muted);
            font-size: 0.8rem;
        }
    </style>
</head>
<body>
    <div class="widget-shell">
        <div class="widget-header">
            <strong>{{ faq_payload.source_system or role_title }}</strong>
            <div class="h5 mb-1 mt-1">{{ faq_payload.page.name if faq_payload.page is defined else page_title }}</div>
            <p>{{ faq_payload.faq_count }} FAQs across {{ faq_payload.section_count if faq_payload.section_count is defined else 1 }} sections on this page</p>
        </div>
        <div class="widget-body">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <h1 class="h5 mb-1">Support Bot</h1>
                            <p class="text-secondary mb-0">Select the FAQ question that best matches your issue. I’ll show the answer immediately, and you can continue until the issue is resolved.</p>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary" type="button" id="restart-page-button">Restart Page</button>
                    </div>

                    <div class="support-link-list mb-4">
                        <a class="btn btn-sm btn-outline-secondary" href="{{ faq_payload.page_url if faq_payload.page_url is defined else '#' }}" target="_blank" rel="noreferrer">Open full FAQ page</a>
                    </div>

                    <div class="transcript mb-4" id="transcript">
                        <div class="bubble-row">
                            <div class="bubble">
                                <div class="bubble-label">Support Bot</div>
                                <div>Select the FAQ question that best matches your issue. I’ll show the answer immediately, and you can continue until the issue is resolved.</div>
                            </div>
                        </div>
                    </div>

                    <div id="section-panel">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h2 class="h6 mb-1">Sections</h2>
                                <p class="text-secondary mb-0">Choose the section that best matches the area you are on.</p>
                            </div>
                        </div>
                        <div class="menu-list" id="section-list"></div>
                    </div>

                    <div class="d-none" id="faq-panel">
                        <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
                            <div>
                                <h2 class="h6 mb-1" id="selected-section-title"></h2>
                                <p class="text-secondary mb-0">Choose the matching question for this section.</p>
                            </div>
                            <button class="btn btn-sm btn-outline-secondary" type="button" id="restart-section-button">Restart Section</button>
                        </div>
                        <div class="question-list" id="question-list"></div>
                    </div>

                    <div class="vstack gap-3 d-none mt-4" id="conversation-panel">
                        <div class="bubble-row bubble-row-user">
                            <div class="bubble">
                                <div class="bubble-label">You</div>
                                <div id="selected-question"></div>
                            </div>
                        </div>
                        <div class="bubble-row">
                            <div class="bubble">
                                <div class="bubble-label">Support Bot</div>
                                <div id="selected-answer"></div>
                                <div class="support-link-list" id="answer-links"></div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap mt-4 d-none" id="resolution-panel">
                        <button class="btn btn-success" type="button" data-resolution="resolved">Resolved</button>
                        <button class="btn btn-outline-primary" type="button" data-resolution="unresolved">Not Resolved</button>
                    </div>

                    <div class="alert rounded-4 mt-4 d-none" id="status-message"></div>
                </div>
            </div>
        </div>
        {% if not embedded %}
            <div class="widget-footer">
                Config API: <code>{{ faq_payload.api_url }}</code>
            </div>
        {% endif %}
    </div>

    <script>
        (() => {
            const rawPayload = {{ faq_payload|tojson }};
            const payload = rawPayload.sections
                ? rawPayload
                : {
                    ...rawPayload,
                    page: rawPayload.page || { name: rawPayload.category ? rawPayload.category.name : "Support", slug: rawPayload.category ? rawPayload.category.slug : "support" },
                    sections: [
                        {
                            id: rawPayload.super_category ? rawPayload.super_category.slug : "default-section",
                            name: rawPayload.super_category ? rawPayload.super_category.name : "Support",
                            slug: rawPayload.super_category ? rawPayload.super_category.slug : "default-section",
                            faq_count: rawPayload.faq_count || (rawPayload.faqs || []).length,
                            category_names: rawPayload.category ? [rawPayload.category.name] : [],
                            faqs: (rawPayload.faqs || []).map((faq) => ({
                                ...faq,
                                category_name: rawPayload.category ? rawPayload.category.name : "",
                            })),
                        },
                    ],
                };

            const transcriptElement = document.getElementById("transcript");
            const sectionPanel = document.getElementById("section-panel");
            const sectionListElement = document.getElementById("section-list");
            const faqPanel = document.getElementById("faq-panel");
            const questionListElement = document.getElementById("question-list");
            const selectedSectionTitleElement = document.getElementById("selected-section-title");
            const restartPageButton = document.getElementById("restart-page-button");
            const restartSectionButton = document.getElementById("restart-section-button");
            const conversationPanel = document.getElementById("conversation-panel");
            const resolutionPanel = document.getElementById("resolution-panel");
            const selectedQuestionElement = document.getElementById("selected-question");
            const selectedAnswerElement = document.getElementById("selected-answer");
            const answerLinksElement = document.getElementById("answer-links");
            const statusMessageElement = document.getElementById("status-message");

            const state = {
                selectedSection: null,
                selectedFaq: null,
                lastSelectedFaq: null,
            };

            function buildLinks(faq) {
                const links = [];
                if (faq.pdf_url) links.push({ label: "PDF", url: faq.pdf_url });
                if (faq.video_url) links.push({ label: "Video", url: faq.video_url });
                return links;
            }

            function setStatus(message, variant) {
                statusMessageElement.className = `alert alert-${variant} rounded-4 mt-4`;
                statusMessageElement.textContent = message;
                statusMessageElement.classList.remove("d-none");
            }

            function clearStatus() {
                statusMessageElement.className = "alert rounded-4 mt-4 d-none";
                statusMessageElement.textContent = "";
            }

            function resetPageFlow() {
                state.selectedSection = null;
                state.selectedFaq = null;
                state.lastSelectedFaq = null;
                sectionPanel.classList.remove("d-none");
                faqPanel.classList.add("d-none");
                conversationPanel.classList.add("d-none");
                resolutionPanel.classList.add("d-none");
                clearStatus();
                renderSections();
            }

            function restartSectionFlow() {
                state.selectedFaq = null;
                state.lastSelectedFaq = null;
                conversationPanel.classList.add("d-none");
                resolutionPanel.classList.add("d-none");
                clearStatus();
                if (!state.selectedSection) {
                    resetPageFlow();
                    return;
                }
                faqPanel.classList.remove("d-none");
                renderQuestions();
            }

            function renderSections() {
                sectionListElement.innerHTML = "";
                payload.sections.forEach((section) => {
                    const wrapper = document.createElement("label");
                    wrapper.className = "question-option";
                    wrapper.innerHTML = `
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="section-selection" value="${section.slug}" id="section-${section.slug}">
                            <span class="form-check-label">${section.name}</span>
                        </div>
                        <span class="question-meta">${section.faq_count} FAQs${section.category_names && section.category_names.length ? ` • ${section.category_names.join(", ")}` : ""}</span>
                    `;
                    sectionListElement.appendChild(wrapper);
                });

                sectionListElement.querySelectorAll("input[name='section-selection']").forEach((input) => {
                    input.addEventListener("change", () => {
                        state.selectedSection = payload.sections.find((section) => section.slug === input.value) || null;
                        state.selectedFaq = null;
                        state.lastSelectedFaq = null;
                        clearStatus();
                        sectionPanel.classList.add("d-none");
                        faqPanel.classList.remove("d-none");
                        conversationPanel.classList.add("d-none");
                        resolutionPanel.classList.add("d-none");
                        renderQuestions();
                    });
                });
            }

            function renderQuestions() {
                questionListElement.innerHTML = "";
                if (!state.selectedSection) {
                    return;
                }

                selectedSectionTitleElement.textContent = state.selectedSection.name;
                state.selectedSection.faqs.forEach((faq) => {
                    const wrapper = document.createElement("label");
                    wrapper.className = "question-option";
                    wrapper.innerHTML = `
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="question-selection" value="${faq.id}" id="faq-${faq.id}">
                            <span class="form-check-label">${faq.question}</span>
                        </div>
                        ${faq.category_name ? `<span class="question-meta">${faq.category_name}</span>` : ""}
                    `;
                    questionListElement.appendChild(wrapper);
                });

                questionListElement.querySelectorAll("input[name='question-selection']").forEach((input) => {
                    input.addEventListener("change", () => {
                        clearStatus();
                        const faq = state.selectedSection.faqs.find((entry) => String(entry.id) === input.value);
                        if (!faq) {
                            setStatus("That question could not be loaded.", "warning");
                            return;
                        }
                        showSelectedAnswer(faq);
                    });
                });
            }

            function showSelectedAnswer(faq) {
                state.selectedFaq = faq;
                state.lastSelectedFaq = faq;
                selectedQuestionElement.textContent = faq.question;
                selectedAnswerElement.textContent = faq.answer || faq.summary || "No answer has been configured yet.";
                answerLinksElement.innerHTML = "";
                buildLinks(faq).forEach((link) => {
                    const anchor = document.createElement("a");
                    anchor.className = "btn btn-sm btn-outline-secondary";
                    anchor.href = link.url;
                    anchor.target = "_blank";
                    anchor.rel = "noopener noreferrer";
                    anchor.textContent = link.label;
                    answerLinksElement.appendChild(anchor);
                });
                faqPanel.classList.add("d-none");
                conversationPanel.classList.remove("d-none");
                resolutionPanel.classList.remove("d-none");
                clearStatus();
            }

            resolutionPanel.querySelectorAll("button[data-resolution]").forEach((button) => {
                button.addEventListener("click", () => {
                    if (button.dataset.resolution === "resolved") {
                        setStatus("Issue marked as resolved. You can restart the page for another issue.", "success");
                        resolutionPanel.classList.add("d-none");
                        return;
                    }
                    setStatus("Please choose another FAQ or open the full FAQ page for a wider section view.", "secondary");
                    restartSectionFlow();
                });
            });

            restartPageButton.addEventListener("click", resetPageFlow);
            restartSectionButton.addEventListener("click", restartSectionFlow);

            renderSections();
        })();
    </script>
</body>
</html>
