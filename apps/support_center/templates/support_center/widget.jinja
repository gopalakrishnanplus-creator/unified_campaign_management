<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --faq-accent: #0f766e;
            --faq-accent-2: #1d4ed8;
            --faq-ink: #0f172a;
            --faq-muted: #64748b;
            --faq-surface: #f8fafc;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(180deg, #f8fafc, #ffffff);
            color: var(--faq-ink);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        .widget-shell {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .widget-header {
            padding: 1rem 1.25rem;
            background: linear-gradient(135deg, var(--faq-accent), var(--faq-accent-2));
            color: white;
        }

        .widget-header p {
            margin: 0;
            opacity: 0.85;
            font-size: 0.85rem;
        }

        .widget-body {
            padding: 1rem;
            display: grid;
            gap: 1rem;
            flex: 1;
            background: var(--faq-surface);
        }

        .transcript {
            display: grid;
            gap: 0.75rem;
            max-height: 38vh;
            overflow-y: auto;
            padding-right: 0.25rem;
        }

        .bubble-row {
            display: flex;
        }

        .bubble-row-user {
            justify-content: flex-end;
        }

        .bubble {
            max-width: 92%;
            border-radius: 1rem;
            padding: 0.85rem 1rem;
            border: 1px solid rgba(15, 23, 42, 0.08);
            background: white;
            box-shadow: 0 10px 20px rgba(15, 23, 42, 0.05);
        }

        .bubble-row-user .bubble {
            background: rgba(29, 78, 216, 0.08);
        }

        .bubble-label {
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--faq-accent);
            margin-bottom: 0.3rem;
        }

        .question-list,
        .resolution-list {
            display: grid;
            gap: 0.75rem;
        }

        .question-option,
        .resolution-option {
            border: 1px solid rgba(15, 23, 42, 0.08);
            border-radius: 1rem;
            background: white;
            padding: 0.85rem 1rem;
        }

        .support-link-list {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-top: 0.75rem;
        }

        .widget-footer {
            padding: 0 1rem 1rem;
            color: var(--faq-muted);
            font-size: 0.8rem;
        }
    </style>
</head>
<body>
    <div class="widget-shell">
        <div class="widget-header">
            <strong>{{ faq_payload.super_category.name }}</strong>
            <div class="h5 mb-1 mt-1">{{ faq_payload.category.name }}</div>
            <p>{{ faq_payload.faq_count }} FAQ questions for this page-specific support widget</p>
        </div>
        <div class="widget-body">
            <div class="transcript" id="transcript"></div>
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <h1 class="h5 mb-1">Customer chat support</h1>
                            <p class="text-secondary mb-0">Select the matching FAQ question. After the answer appears, mark it resolved or return to the list. Use Other when the issue is not listed.</p>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary" type="button" id="restart-button">Restart</button>
                    </div>

                    <form id="faq-form" class="vstack gap-3">
                        <div class="question-list" id="question-list"></div>
                        <button class="btn btn-primary" type="submit">Show Answer</button>
                    </form>

                    <div class="card bg-light-subtle border-0 rounded-4 mt-4 d-none" id="answer-panel">
                        <div class="card-body">
                            <p class="eyebrow mb-2">Selected question</p>
                            <h2 class="h6 mb-2" id="selected-question"></h2>
                            <p class="mb-0" id="selected-answer"></p>
                            <div class="support-link-list" id="answer-links"></div>
                        </div>
                    </div>

                    <form class="vstack gap-3 mt-4 d-none" id="resolution-form">
                        <div class="resolution-list">
                            <label class="resolution-option d-flex gap-3 align-items-start">
                                <input class="form-check-input mt-1" type="radio" name="resolution" value="resolved" checked>
                                <span>Resolved</span>
                            </label>
                            <label class="resolution-option d-flex gap-3 align-items-start">
                                <input class="form-check-input mt-1" type="radio" name="resolution" value="unresolved">
                                <span>Not Resolved</span>
                            </label>
                        </div>
                        <button class="btn btn-outline-primary" type="submit">Continue</button>
                    </form>

                    <form class="vstack gap-3 mt-4 d-none" id="other-form" enctype="multipart/form-data">
                        <div>
                            <label class="form-label" for="other-description">Describe the issue</label>
                            <textarea class="form-control" id="other-description" name="free_text" rows="4" placeholder="Describe what happened and what the user was trying to do."></textarea>
                        </div>
                        <div>
                            <label class="form-label" for="other-file">Upload screenshot or image</label>
                            <input class="form-control" id="other-file" type="file" name="uploaded_file" accept=".jpg,.jpeg,.png,.heic,.svg,.webp">
                            <div class="form-text">Allowed formats: .jpg, .jpeg, .png, .heic, .svg, .webp</div>
                        </div>
                        <button class="btn btn-primary" type="submit">Send to PM dashboard</button>
                    </form>

                    <div class="alert rounded-4 mt-4 d-none" id="status-message"></div>
                </div>
            </div>
        </div>
        {% if not embedded %}
            <div class="widget-footer">
                Config API: <code>{{ faq_payload.api_url }}</code>
            </div>
        {% endif %}
    </div>

    <script>
        (() => {
            const apiUrl = {{ faq_payload.api_url|tojson }};
            const otherIssueUrl = {{ faq_payload.other_issue_url|tojson }};
            const transcriptElement = document.getElementById("transcript");
            const questionListElement = document.getElementById("question-list");
            const faqForm = document.getElementById("faq-form");
            const restartButton = document.getElementById("restart-button");
            const answerPanel = document.getElementById("answer-panel");
            const resolutionForm = document.getElementById("resolution-form");
            const otherForm = document.getElementById("other-form");
            const selectedQuestionElement = document.getElementById("selected-question");
            const selectedAnswerElement = document.getElementById("selected-answer");
            const answerLinksElement = document.getElementById("answer-links");
            const statusMessageElement = document.getElementById("status-message");

            const state = {
                faqs: [],
                selectedFaq: null,
            };

            function getCookie(name) {
                const cookieValue = document.cookie
                    .split(";")
                    .map((item) => item.trim())
                    .find((item) => item.startsWith(`${name}=`));
                return cookieValue ? decodeURIComponent(cookieValue.split("=").slice(1).join("=")) : "";
            }

            function appendMessage(role, title, body) {
                const row = document.createElement("div");
                row.className = `bubble-row ${role === "user" ? "bubble-row-user" : ""}`;

                const bubble = document.createElement("div");
                bubble.className = "bubble";

                const label = document.createElement("div");
                label.className = "bubble-label";
                label.textContent = title;
                bubble.appendChild(label);

                const text = document.createElement("div");
                text.textContent = body;
                bubble.appendChild(text);

                row.appendChild(bubble);
                transcriptElement.appendChild(row);
                transcriptElement.scrollTop = transcriptElement.scrollHeight;
            }

            function setStatus(message, variant) {
                statusMessageElement.className = `alert alert-${variant} rounded-4 mt-4`;
                statusMessageElement.textContent = message;
                statusMessageElement.classList.remove("d-none");
            }

            function clearStatus() {
                statusMessageElement.className = "alert rounded-4 mt-4 d-none";
                statusMessageElement.textContent = "";
            }

            function buildLinks(faq) {
                const links = [];
                if (faq.pdf_url) {
                    links.push({ label: "PDF", url: faq.pdf_url });
                }
                if (faq.video_url) {
                    links.push({ label: "Video", url: faq.video_url });
                }
                return links;
            }

            function renderQuestions() {
                questionListElement.innerHTML = "";
                state.faqs.forEach((faq) => {
                    const wrapper = document.createElement("label");
                    wrapper.className = "question-option";
                    wrapper.innerHTML = `
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="selection" value="${faq.id}" id="faq-${faq.id}" ${state.selectedFaq && state.selectedFaq.id === faq.id ? "checked" : ""}>
                            <span class="form-check-label">${faq.question}</span>
                        </div>
                    `;
                    questionListElement.appendChild(wrapper);
                });

                const otherWrapper = document.createElement("label");
                otherWrapper.className = "question-option";
                otherWrapper.innerHTML = `
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="selection" value="other" id="faq-other">
                        <span class="form-check-label">Other</span>
                    </div>
                `;
                questionListElement.appendChild(otherWrapper);
            }

            function resetPanels() {
                state.selectedFaq = null;
                answerPanel.classList.add("d-none");
                resolutionForm.classList.add("d-none");
                otherForm.classList.add("d-none");
                clearStatus();
                faqForm.reset();
            }

            function showSelectedAnswer(faq) {
                state.selectedFaq = faq;
                selectedQuestionElement.textContent = faq.question;
                selectedAnswerElement.textContent = faq.answer || faq.summary || "No answer has been configured yet.";
                answerLinksElement.innerHTML = "";
                buildLinks(faq).forEach((link) => {
                    const anchor = document.createElement("a");
                    anchor.className = "btn btn-sm btn-outline-secondary";
                    anchor.href = link.url;
                    anchor.target = "_blank";
                    anchor.rel = "noopener noreferrer";
                    anchor.textContent = link.label;
                    answerLinksElement.appendChild(anchor);
                });
                answerPanel.classList.remove("d-none");
                resolutionForm.classList.remove("d-none");
                otherForm.classList.add("d-none");
                clearStatus();
                appendMessage("user", "You", faq.question);
                appendMessage("bot", "Support Bot", faq.answer || faq.summary || "No answer has been configured yet.");
            }

            function resetConversation() {
                transcriptElement.innerHTML = "";
                resetPanels();
                renderQuestions();
                appendMessage(
                    "bot",
                    "Support Bot",
                    "Select the FAQ question that best matches your issue. I’ll show the answer immediately, and you can continue until the issue is resolved."
                );
            }

            async function loadFaqs() {
                const response = await fetch(apiUrl);
                const payload = await response.json();
                state.faqs = payload.faqs || [];
                resetConversation();
            }

            faqForm.addEventListener("submit", (event) => {
                event.preventDefault();
                clearStatus();
                const selected = faqForm.querySelector("input[name='selection']:checked");
                if (!selected) {
                    setStatus("Please select a question or choose Other.", "warning");
                    return;
                }

                if (selected.value === "other") {
                    answerPanel.classList.add("d-none");
                    resolutionForm.classList.add("d-none");
                    otherForm.classList.remove("d-none");
                    appendMessage("user", "You", "Other");
                    appendMessage("bot", "Support Bot", "Please describe the issue and upload one image if that helps. This will go to the PM dashboard for review.");
                    return;
                }

                const faq = state.faqs.find((entry) => String(entry.id) === selected.value);
                if (!faq) {
                    setStatus("That question could not be loaded.", "warning");
                    return;
                }
                showSelectedAnswer(faq);
            });

            resolutionForm.addEventListener("submit", (event) => {
                event.preventDefault();
                const selectedResolution = resolutionForm.querySelector("input[name='resolution']:checked");
                if (!selectedResolution) {
                    setStatus("Please choose Resolved or Not Resolved.", "warning");
                    return;
                }

                if (selectedResolution.value === "resolved") {
                    setStatus("Issue marked as resolved. You can restart the widget for another issue.", "success");
                    appendMessage("bot", "Support Bot", "Great. I’ve marked this issue as resolved.");
                    resolutionForm.classList.add("d-none");
                    otherForm.classList.add("d-none");
                    return;
                }

                appendMessage("user", "You", "Not Resolved");
                appendMessage("bot", "Support Bot", "Okay, please select another question from the list or choose Other.");
                resetPanels();
                renderQuestions();
            });

            otherForm.addEventListener("submit", async (event) => {
                event.preventDefault();
                clearStatus();
                const formData = new FormData(otherForm);
                if (!(formData.get("free_text") || "").trim()) {
                    setStatus("Please describe the issue before sending it to the PM dashboard.", "warning");
                    return;
                }
                try {
                    const response = await fetch(otherIssueUrl, {
                        method: "POST",
                        headers: {
                            "X-CSRFToken": getCookie("csrftoken"),
                        },
                        body: formData,
                    });
                    const payload = await response.json();
                    if (!response.ok || !payload.success) {
                        setStatus("The issue could not be submitted. Please review the details and try again.", "danger");
                        return;
                    }
                    appendMessage("user", "You", formData.get("free_text"));
                    appendMessage("bot", "Support Bot", payload.message || "Issue recorded for PM review.");
                    setStatus(payload.message || "Issue recorded for PM review.", "success");
                    otherForm.reset();
                    answerPanel.classList.add("d-none");
                    resolutionForm.classList.add("d-none");
                } catch (error) {
                    setStatus("The issue could not be submitted right now. Please try again.", "danger");
                }
            });

            restartButton.addEventListener("click", () => {
                resetConversation();
            });

            loadFaqs();
        })();
    </script>
</body>
</html>
