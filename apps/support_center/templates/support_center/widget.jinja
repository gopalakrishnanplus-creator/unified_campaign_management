<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --faq-accent: #0f766e;
            --faq-accent-2: #1d4ed8;
            --faq-ink: #0f172a;
            --faq-muted: #64748b;
            --faq-surface: #f8fafc;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(180deg, #f8fafc, #ffffff);
            color: var(--faq-ink);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        .widget-shell {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .widget-header {
            padding: 1rem 1.25rem;
            background: linear-gradient(135deg, var(--faq-accent), var(--faq-accent-2));
            color: white;
        }

        .widget-header p {
            margin: 0;
            opacity: 0.85;
            font-size: 0.85rem;
        }

        .widget-body {
            padding: 1rem;
            display: grid;
            gap: 1rem;
            flex: 1;
            background: var(--faq-surface);
        }

        .transcript {
            display: grid;
            gap: 0.75rem;
            max-height: 38vh;
            overflow-y: auto;
            padding-right: 0.25rem;
        }

        .bubble-row {
            display: flex;
        }

        .bubble-row-user {
            justify-content: flex-end;
        }

        .bubble {
            max-width: 92%;
            border-radius: 1rem;
            padding: 0.85rem 1rem;
            border: 1px solid rgba(15, 23, 42, 0.08);
            background: white;
            box-shadow: 0 10px 20px rgba(15, 23, 42, 0.05);
        }

        .bubble-row-user .bubble {
            background: rgba(29, 78, 216, 0.08);
        }

        .bubble-label {
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--faq-accent);
            margin-bottom: 0.3rem;
        }

        .question-list,
        .resolution-list {
            display: grid;
            gap: 0.75rem;
        }

        .question-option,
        .resolution-option {
            border: 1px solid rgba(15, 23, 42, 0.08);
            border-radius: 1rem;
            background: white;
            padding: 0.85rem 1rem;
        }

        .support-link-list {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-top: 0.75rem;
        }

        .widget-footer {
            padding: 0 1rem 1rem;
            color: var(--faq-muted);
            font-size: 0.8rem;
        }
    </style>
</head>
<body>
    <div class="widget-shell">
        <div class="widget-header">
            <strong>{{ faq_payload.super_category.name }}</strong>
            <div class="h5 mb-1 mt-1">{{ faq_payload.category.name }}</div>
            <p>{{ faq_payload.faq_count }} FAQ questions for this page-specific support widget</p>
        </div>
        <div class="widget-body">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <div id="selection-panel">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <h1 class="h5 mb-1">Support Bot</h1>
                                <p class="text-secondary mb-0">Select the FAQ question that best matches your issue. I’ll show the answer immediately, and you can continue until the issue is resolved.</p>
                            </div>
                            <button class="btn btn-sm btn-outline-secondary" type="button" id="restart-button">Restart</button>
                        </div>
                        <div class="question-list" id="question-list"></div>
                    </div>

                    <div class="vstack gap-3 d-none" id="conversation-panel">
                        <div class="bubble-row bubble-row-user">
                            <div class="bubble">
                                <div class="bubble-label">You</div>
                                <div id="selected-question"></div>
                            </div>
                        </div>
                        <div class="bubble-row">
                            <div class="bubble">
                                <div class="bubble-label">Support Bot</div>
                                <div id="selected-answer"></div>
                                <div class="support-link-list" id="answer-links"></div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap mt-4 d-none" id="resolution-panel">
                        <button class="btn btn-success" type="button" data-resolution="resolved">Resolved</button>
                        <button class="btn btn-outline-primary" type="button" data-resolution="unresolved">Not Resolved</button>
                    </div>

                    <form class="vstack gap-3 mt-4 d-none" id="other-form" enctype="multipart/form-data">
                        <div>
                            <label class="form-label" for="other-description">Describe the issue</label>
                            <textarea class="form-control" id="other-description" name="free_text" rows="4" placeholder="Describe what happened and what the user was trying to do."></textarea>
                        </div>
                        <div>
                            <label class="form-label" for="other-file">Upload screenshot or image</label>
                            <input class="form-control" id="other-file" type="file" name="uploaded_file" accept=".jpg,.jpeg,.png,.heic,.svg,.webp">
                            <div class="form-text">Allowed formats: .jpg, .jpeg, .png, .heic, .svg, .webp</div>
                        </div>
                        <button class="btn btn-primary" type="submit">Raise Query</button>
                    </form>

                    <div class="alert rounded-4 mt-4 d-none" id="status-message"></div>
                </div>
            </div>
        </div>
        {% if not embedded %}
            <div class="widget-footer">
                Config API: <code>{{ faq_payload.api_url }}</code>
            </div>
        {% endif %}
    </div>

    <script>
        (() => {
            const apiUrl = {{ faq_payload.api_url|tojson }};
            const otherIssueUrl = {{ faq_payload.other_issue_url|tojson }};
            const selectionPanel = document.getElementById("selection-panel");
            const questionListElement = document.getElementById("question-list");
            const restartButton = document.getElementById("restart-button");
            const conversationPanel = document.getElementById("conversation-panel");
            const resolutionPanel = document.getElementById("resolution-panel");
            const otherForm = document.getElementById("other-form");
            const selectedQuestionElement = document.getElementById("selected-question");
            const selectedAnswerElement = document.getElementById("selected-answer");
            const answerLinksElement = document.getElementById("answer-links");
            const statusMessageElement = document.getElementById("status-message");

            const state = {
                payload: null,
                faqs: [],
                selectedFaq: null,
                lastSelectedFaq: null,
            };

            function getCookie(name) {
                const cookieValue = document.cookie
                    .split(";")
                    .map((item) => item.trim())
                    .find((item) => item.startsWith(`${name}=`));
                return cookieValue ? decodeURIComponent(cookieValue.split("=").slice(1).join("=")) : "";
            }

            function inferSystemFromReferrer(referrer) {
                const value = (referrer || "").toLowerCase();
                if (!value) return "";
                if (value.includes("in-clinic") || value.includes("inclinic")) return "In-clinic";
                if (value.includes("patient-education") || value.includes("patienteducation") || value.includes("patient_education")) return "Patient Education";
                if (value.includes("red-flag") || value.includes("red_flag") || value.includes("redflag") || value.includes("/rfa") || value.includes("sapa")) {
                    return "Red Flag Alert";
                }
                return "";
            }

            function setStatus(message, variant) {
                statusMessageElement.className = `alert alert-${variant} rounded-4 mt-4`;
                statusMessageElement.textContent = message;
                statusMessageElement.classList.remove("d-none");
            }

            function clearStatus() {
                statusMessageElement.className = "alert rounded-4 mt-4 d-none";
                statusMessageElement.textContent = "";
            }

            function buildLinks(faq) {
                const links = [];
                if (faq.pdf_url) {
                    links.push({ label: "PDF", url: faq.pdf_url });
                }
                if (faq.video_url) {
                    links.push({ label: "Video", url: faq.video_url });
                }
                return links;
            }

            function showSelectionPanel() {
                selectionPanel.classList.remove("d-none");
                conversationPanel.classList.add("d-none");
                resolutionPanel.classList.add("d-none");
                otherForm.classList.add("d-none");
            }

            function hideSelectionPanel() {
                selectionPanel.classList.add("d-none");
            }

            function renderQuestions() {
                questionListElement.innerHTML = "";
                state.faqs.forEach((faq) => {
                    const wrapper = document.createElement("label");
                    wrapper.className = "question-option";
                    wrapper.innerHTML = `
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="selection" value="${faq.id}" id="faq-${faq.id}" ${state.selectedFaq && state.selectedFaq.id === faq.id ? "checked" : ""}>
                            <span class="form-check-label">${faq.question}</span>
                        </div>
                    `;
                    questionListElement.appendChild(wrapper);
                });

                const otherWrapper = document.createElement("label");
                otherWrapper.className = "question-option";
                otherWrapper.innerHTML = `
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="selection" value="other" id="faq-other">
                        <span class="form-check-label">Other</span>
                    </div>
                `;
                questionListElement.appendChild(otherWrapper);

                questionListElement.querySelectorAll("input[name='selection']").forEach((input) => {
                    input.addEventListener("change", () => {
                        clearStatus();
                        if (input.value === "other") {
                            hideSelectionPanel();
                            conversationPanel.classList.add("d-none");
                            otherForm.classList.remove("d-none");
                            return;
                        }

                        const faq = state.faqs.find((entry) => String(entry.id) === input.value);
                        if (!faq) {
                            setStatus("That question could not be loaded.", "warning");
                            return;
                        }
                        showSelectedAnswer(faq);
                    });
                });
            }

            function resetPanels() {
                state.selectedFaq = null;
                showSelectionPanel();
                clearStatus();
                questionListElement.querySelectorAll("input[name='selection']").forEach((input) => {
                    input.checked = false;
                });
                otherForm.reset();
            }

            function showSelectedAnswer(faq) {
                state.selectedFaq = faq;
                state.lastSelectedFaq = faq;
                selectedQuestionElement.textContent = faq.question;
                selectedAnswerElement.textContent = faq.answer || faq.summary || "No answer has been configured yet.";
                answerLinksElement.innerHTML = "";
                buildLinks(faq).forEach((link) => {
                    const anchor = document.createElement("a");
                    anchor.className = "btn btn-sm btn-outline-secondary";
                    anchor.href = link.url;
                    anchor.target = "_blank";
                    anchor.rel = "noopener noreferrer";
                    anchor.textContent = link.label;
                    answerLinksElement.appendChild(anchor);
                });
                hideSelectionPanel();
                conversationPanel.classList.remove("d-none");
                resolutionPanel.classList.remove("d-none");
                otherForm.classList.add("d-none");
                clearStatus();
            }

            function resetConversation() {
                state.lastSelectedFaq = null;
                resetPanels();
                renderQuestions();
            }

            async function loadFaqs() {
                const response = await fetch(apiUrl);
                const payload = await response.json();
                state.payload = payload;
                state.faqs = payload.faqs || [];
                resetConversation();
            }

            resolutionPanel.querySelectorAll("button[data-resolution]").forEach((button) => {
                button.addEventListener("click", () => {
                    if (button.dataset.resolution === "resolved") {
                        setStatus("Issue marked as resolved. You can restart the widget for another issue.", "success");
                        resolutionPanel.classList.add("d-none");
                        otherForm.classList.add("d-none");
                        return;
                    }

                    setStatus("Please select another question or choose Other.", "secondary");
                    resetPanels();
                    renderQuestions();
                });
            });

            otherForm.addEventListener("submit", async (event) => {
                event.preventDefault();
                clearStatus();
                const formData = new FormData(otherForm);
                if (!(formData.get("free_text") || "").trim()) {
                    setStatus("Please describe the issue before raising the query.", "warning");
                    return;
                }
                formData.set("context_referrer", document.referrer || "");
                const contextFaq = state.selectedFaq || state.lastSelectedFaq;
                const inferredSystem = inferSystemFromReferrer(document.referrer);
                if (inferredSystem) {
                    formData.set("source_system", inferredSystem);
                    if (state.payload && state.payload.super_category && state.payload.super_category.name) {
                        formData.set("source_flow", state.payload.super_category.name);
                    }
                } else if (state.payload && state.payload.source_system) {
                    formData.set("source_system", state.payload.source_system);
                    if (state.payload.source_flow) {
                        formData.set("source_flow", state.payload.source_flow);
                    }
                }
                if (contextFaq) {
                    formData.set("selected_faq_id", String(contextFaq.id));
                    if (!formData.get("source_system") && contextFaq.source_system) {
                        formData.set("source_system", contextFaq.source_system);
                    }
                    if (!formData.get("source_flow") && contextFaq.source_flow) {
                        formData.set("source_flow", contextFaq.source_flow);
                    }
                }
                try {
                    const response = await fetch(otherIssueUrl, {
                        method: "POST",
                        headers: {
                            "X-CSRFToken": getCookie("csrftoken"),
                        },
                        body: formData,
                    });
                    const payload = await response.json();
                    if (!response.ok || !payload.success) {
                        setStatus("The issue could not be submitted. Please review the details and try again.", "danger");
                        return;
                    }
                    setStatus(payload.message || "Issue recorded for PM review.", "success");
                    conversationPanel.classList.add("d-none");
                    resolutionPanel.classList.add("d-none");
                } catch (error) {
                    setStatus("The issue could not be submitted right now. Please try again.", "danger");
                }
            });

            restartButton.addEventListener("click", () => {
                resetConversation();
            });

            loadFaqs();
        })();
    </script>
</body>
</html>
