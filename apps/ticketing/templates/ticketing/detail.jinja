{% extends "base.jinja" %}
{% block title %}{{ ticket.ticket_number }}{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
    <div>
        <p class="eyebrow mb-1">Ticket {{ ticket.ticket_number }}</p>
        <h1 class="mb-1">{{ ticket.title }}</h1>
        <p class="text-secondary mb-0">{{ ticket.description }}</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <span class="priority-pill {{ ticket.priority_badge_class }}">{{ ticket.get_priority_display() }}</span>
        <span class="status-pill {{ ticket.status_badge_class }}">{{ ticket.get_status_display() }}</span>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Classification</h2>
                <div class="metric-row"><span>Category</span><strong>{{ ticket.ticket_category.name if ticket.ticket_category else 'Uncategorized' }}</strong></div>
                <div class="metric-row"><span>Type</span><strong>{{ ticket.ticket_type }}</strong></div>
                <div class="metric-row"><span>Source system</span><strong>{{ ticket.get_source_system_display() }}</strong></div>
                <div class="metric-row"><span>User type</span><strong>{{ ticket.get_user_type_display() }}</strong></div>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Assignment</h2>
                <div class="metric-row"><span>Department</span><strong>{{ ticket.department.name }}</strong></div>
                <div class="metric-row"><span>Direct recipient</span><strong>{{ ticket.direct_recipient.full_name or ticket.direct_recipient.email }}</strong></div>
                <div class="metric-row"><span>Current assignee</span><strong>{{ ticket.current_assignee.full_name or ticket.current_assignee.email }}</strong></div>
                <div class="metric-row"><span>Campaign</span><strong>{{ ticket.campaign.name if ticket.campaign else 'Unassigned' }}</strong></div>
                <div class="metric-row"><span>Requester</span><strong>{{ ticket.requester_name }}</strong></div>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Internal ticketing sync</h2>
                {% if ticket.external_ticket_number %}
                    <div class="metric-row"><span>External ticket</span><strong>{{ ticket.external_ticket_number }}</strong></div>
                    <div class="metric-row"><span>External status</span><strong>{{ ticket.external_ticket_status or 'Synced' }}</strong></div>
                    <div class="metric-row"><span>Last synced</span><strong>{{ ticket.external_ticket_synced_at|india_datetime if ticket.external_ticket_synced_at else 'Just now' }}</strong></div>
                    {% if ticket.external_ticket_url %}
                        <a class="btn btn-outline-primary btn-sm mt-3" href="{{ ticket.external_ticket_url }}" target="_blank" rel="noreferrer">Open internal ticket</a>
                    {% endif %}
                {% elif ticket.external_ticket_error %}
                    <div class="alert alert-warning mb-0">
                        <strong>Sync pending.</strong> {{ ticket.external_ticket_error }}
                    </div>
                {% else %}
                    <p class="text-secondary mb-0">This ticket has not been mirrored to the internal ticketing system yet.</p>
                {% endif %}
                {% if ticket.external_ticket_log %}
                    <div class="mt-3">
                        <p class="small text-secondary mb-2">Sync log</p>
                        <pre class="small bg-light border rounded-3 p-3 mb-0" style="white-space: pre-wrap;">{{ ticket.external_ticket_log }}</pre>
                    </div>
                {% endif %}
            </div>
        </div>

        {% if ticket_management_locked %}
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h2 class="h5 mb-3">Ticket management</h2>
                    <p class="text-secondary mb-0">Status and delegation are managed in the Inditech ticketing system for mirrored tickets. Any updates made there will sync back into this dashboard.</p>
                    {% if ticket.external_ticket_url %}
                        <a class="btn btn-outline-primary btn-sm mt-3" href="{{ ticket.external_ticket_url }}" target="_blank" rel="noreferrer">Manage in Inditech ticketing</a>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body">
                    <h2 class="h5 mb-3">Status update</h2>
                    <form method="post" class="vstack gap-3">
                        {{ csrf_input }}
                        <input type="hidden" name="action" value="status">
                        {{ status_form.status }}
                        <button class="btn btn-primary" type="submit">Change status</button>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h2 class="h5 mb-3">Delegate ticket</h2>
                    <form method="post" class="vstack gap-3">
                        {{ csrf_input }}
                        <input type="hidden" name="action" value="delegate">
                        {{ delegation_form.assignee }}
                        <button class="btn btn-outline-primary" type="submit">Delegate</button>
                    </form>
                    {% if ticket.created_by %}
                        <form method="post" class="mt-3">
                            {{ csrf_input }}
                            <input type="hidden" name="action" value="return">
                            <button class="btn btn-outline-secondary" type="submit">Return to sender</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Add note</h2>
                <form method="post" enctype="multipart/form-data" class="vstack gap-3">
                    {{ csrf_input }}
                    <input type="hidden" name="action" value="note">
                    {{ note_form.body }}
                    {{ note_form.attachments }}
                    <p class="small text-secondary mb-0">Up to three attachments, 5 MB each.</p>
                    <button class="btn btn-primary align-self-start" type="submit">Add note</button>
                </form>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Notes</h2>
                <div class="timeline timeline-scroll">
                    {% for note in ticket.notes.all() %}
                        <div class="timeline-item">
                            <div class="d-flex justify-content-between mb-2">
                                <strong>{{ note.author.full_name or note.author.email }}</strong>
                                <span class="text-secondary small">{{ note.created_at|india_datetime }}</span>
                            </div>
                            <p class="mb-2">{{ note.body }}</p>
                            {% if note.attachments.all() %}
                                <div class="d-flex gap-2 flex-wrap">
                                    {% for attachment in note.attachments.all() %}
                                        <a class="btn btn-sm btn-outline-secondary" href="{{ attachment.file.url }}">{{ attachment.file.name.split('/')[-1] }}</a>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    {% else %}
                        <p class="text-secondary mb-0">No notes yet.</p>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Routing history</h2>
                <div class="timeline timeline-scroll">
                    {% for event in ticket.routing_events.all() %}
                        <div class="timeline-item">
                            <div class="d-flex justify-content-between mb-1">
                                <strong>{{ event.get_action_display() }}</strong>
                                <span class="text-secondary small">{{ event.created_at|india_datetime }}</span>
                            </div>
                            <p class="mb-0 text-secondary">{{ event.description }}</p>
                        </div>
                    {% else %}
                        <p class="text-secondary mb-0">No routing activity yet.</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
