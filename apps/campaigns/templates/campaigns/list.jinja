{% extends "base.jinja" %}
{% block title %}Campaigns{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <p class="eyebrow mb-1">Campaigns</p>
        <h1 class="mb-1">Managed campaigns</h1>
        <p class="text-secondary mb-0">Campaigns, enrolled clinics, and field-rep assignments that feed the support and performance dashboards.</p>
    </div>
</div>
<div class="row g-4">
    {% for campaign in campaigns %}
        <div class="col-md-6 col-xl-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <p class="eyebrow mb-1">{{ campaign.brand_name }}</p>
                    <h2 class="h5">{{ campaign.name }}</h2>
                    <p class="text-secondary">{{ campaign.description }}</p>
                    <div class="vstack gap-2 mb-3">
                        <div class="metric-row"><span>Status</span><strong>{{ campaign.get_status_display() }}</strong></div>
                        <div class="metric-row"><span>Clinics</span><strong>{{ campaign.enrolled_clinics }}</strong></div>
                        <div class="metric-row"><span>Field reps</span><strong>{{ campaign.assigned_field_reps }}</strong></div>
                    </div>
                    <a class="btn btn-outline-primary" href="{{ url('campaigns:detail', slug=campaign.slug) }}">Open campaign</a>
                </div>
            </div>
        </div>
    {% endfor %}
</div>
{% endblock %}
